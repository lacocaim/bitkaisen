screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = 1080
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = playerGui

local function viewport()
	local camera = workspace.CurrentCamera
	return camera and camera.ViewportSize or Vector2.new(1280, 720)
end

local function isSmallScreen()
	local v = viewport()
	return v.X < 850 or v.Y < 560 or UserInputService.TouchEnabled
end

local function nextZ(parent, bump)
	local parentZ = 1

	if parent and parent:IsA("GuiObject") then
		parentZ = parent.ZIndex
	end

	return parentZ + (bump or 1)
end

local function addCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or 10)
	corner.Parent = parent
	return corner
end

local function addStroke(parent, color, thickness, transparency)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color or THEME.Stroke
	stroke.Thickness = thickness or 1
	stroke.Transparency = transparency or 0
	stroke.Parent = parent
	return stroke
end

local function addPadding(parent, left, right, top, bottom)
	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, left or 0)
	padding.PaddingRight = UDim.new(0, right or 0)
	padding.PaddingTop = UDim.new(0, top or 0)
	padding.PaddingBottom = UDim.new(0, bottom or 0)
	padding.Parent = parent
	return padding
end

local function tween(instance, duration, props)
	local tw = TweenService:Create(
		instance,
		TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		props
	)

	tw:Play()
	return tw
end

local function setHover(button, hoverColor)
	local baseColor = button.BackgroundColor3

	button.MouseEnter:Connect(function()
		if button.Active then
			tween(button, 0.12, {
				BackgroundColor3 = hoverColor or THEME.ButtonHover,
			})
		end
	end)

	button.MouseLeave:Connect(function()
		tween(button, 0.12, {
			BackgroundColor3 = baseColor,
		})
	end)
end

local function makeText(parent, name, text, size, color, bold)
	local label = Instance.new("TextLabel")
	label.Name = name
	label.BackgroundTransparency = 1
	label.BorderSizePixel = 0
	label.Text = text or ""
	label.TextColor3 = color or THEME.Text
	label.TextSize = size or 14
	label.Font = bold and Enum.Font.GothamBlack or Enum.Font.GothamMedium
	label.TextWrapped = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Top
	label.RichText = true
	label.ZIndex = nextZ(parent, 2)
	label.Parent = parent
	return label
end

local function makeButton(parent, name, text, color)
	local button = Instance.new("TextButton")
	button.Name = name
	button.BackgroundColor3 = color or THEME.Button
	button.BorderSizePixel = 0
	button.Text = text or "BUTTON"
	button.TextColor3 = THEME.Text
	button.TextSize = 12
	button.Font = Enum.Font.GothamBlack
	button.AutoButtonColor = false
	button.Active = true
	button.ZIndex = nextZ(parent, 3)
	button.Parent = parent

	addCorner(button, 9)
	addStroke(button, THEME.StrokeSoft, 1, 0)
	setHover(button, THEME.ButtonHover)

	return button
end

local function clearGuiObjects(parent)
	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("GuiObject") or child:IsA("UIListLayout") or child:IsA("UIPadding") then
			child:Destroy()
		end
	end
end

local function safeNumber(value, defaultValue)
	local number = tonumber(value)
	if number == nil then
		return defaultValue or 0
	end

	return number
end

local function getStatLine()
	if typeof(currentStats) ~= "table" then
		return "No active life loaded."
	end

	local age = safeNumber(currentStats.Age, 0)
	local month = tostring(currentStats.CurrentMonthName or currentStats.CurrentMonth or "")
	local grade = tostring(currentStats.Grade or "Non-Sorcerer")
	local ce = safeNumber(currentStats.CursedEnergy, 0)
	local mastery = safeNumber(currentStats.TechniqueMastery, 0)

	if month ~= "" then
		return "Age " .. tostring(age) .. " • " .. month .. " • " .. grade .. " • CE " .. tostring(ce) .. " • Mastery " .. tostring(mastery)
	end

	return "Age " .. tostring(age) .. " • " .. grade .. " • CE " .. tostring(ce) .. " • Mastery " .. tostring(mastery)
end

local function getCustomOptions()
	local payload = currentPayload or {}
	local options = typeof(payload.CustomOptions) == "table" and payload.CustomOptions or {}

	return {
		Sacrifices = typeof(options.Sacrifices) == "table" and options.Sacrifices or {},
		Rewards = typeof(options.Rewards) == "table" and options.Rewards or {},
		Severities = typeof(options.Severities) == "table" and options.Severities or {},
	}
end

local function getSelected(list, index)
	if typeof(list) ~= "table" or #list <= 0 then
		return nil
	end

	index = math.clamp(index, 1, #list)
	return list[index]
end

local function cycleIndex(list, index, direction)
	if typeof(list) ~= "table" or #list <= 0 then
		return 1
	end

	index += direction

	if index > #list then
		index = 1
	elseif index < 1 then
		index = #list
	end

	return index
end

local function activeVowCount(payload)
	if typeof(payload) ~= "table" then
		return 0
	end

	local count = 0

	if typeof(payload.ActiveVows) == "table" then
		count += #payload.ActiveVows
	end

	if typeof(payload.CustomVows) == "table" then
		for _, vow in ipairs(payload.CustomVows) do
			if vow and vow.Owned == true then
				count += 1
			end
		end
	end

	return count
end

local function refreshOpenBadge()
	if not openBadge then
		return
	end

	local count = activeVowCount(currentPayload)
	openBadge.Text = tostring(count)
	openBadge.Visible = count > 0
end

local function getPowerFromSeverity(severity)
	local id = tostring(severity and severity.Id or "")
	return PREVIEW_RULES.SeverityPower[id] or 1
end

local function getCostText(sacrifice, power)
	local id = tostring(sacrifice and sacrifice.Id or "")
	local builder = PREVIEW_RULES.SacrificeCost[id]

	if builder then
		return builder(power)
	end

	return "Cost depends on the selected sacrifice."
end

local function getGainText(reward, power)
	local id = tostring(reward and reward.Id or "")
	local builder = PREVIEW_RULES.RewardGain[id]

	if builder then
		return builder(power)
	end

	return "Gain depends on the selected reward."
end

local function getPenaltyText(sacrifice, reward, power)
	local sacrificeId = tostring(sacrifice and sacrifice.Id or "")
	local rewardId = tostring(reward and reward.Id or "")

	local sacrificeBuilder = PREVIEW_RULES.SacrificeBreak[sacrificeId]
	local rewardBuilder = PREVIEW_RULES.RewardBreak[rewardId]

	local sacrificeText = sacrificeBuilder and sacrificeBuilder(power) or "sacrifice backlash"
	local rewardText = rewardBuilder and rewardBuilder(power) or "reward backlash"

	return "Breaking this signed vow causes backlash: " .. sacrificeText .. ", " .. rewardText .. ", and -" .. tostring(8 * power) .. " Reputation."
end

