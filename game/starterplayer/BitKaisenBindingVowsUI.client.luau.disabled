local function updateCanvas()
	if not contentLayout or not contentPadding then
		content.CanvasSize = UDim2.new(0, 0, 0, 0)
		return
	end

	local contentHeight = contentLayout.AbsoluteContentSize.Y + contentPadding.PaddingTop.Offset + contentPadding.PaddingBottom.Offset + 36
	content.CanvasSize = UDim2.new(0, 0, 0, contentHeight)
end

local function installContentLayout()
	contentLayout = Instance.new("UIListLayout")
	contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
	contentLayout.Padding = UDim.new(0, 10)
	contentLayout.Parent = content

	contentPadding = Instance.new("UIPadding")
	contentPadding.PaddingTop = UDim.new(0, 12)
	contentPadding.PaddingBottom = UDim.new(0, 18)
	contentPadding.PaddingLeft = UDim.new(0, 12)
	contentPadding.PaddingRight = UDim.new(0, 12)
	contentPadding.Parent = content

	contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
end

installContentLayout()

local function fetchPayload()
	if loading then
		return currentPayload
	end

	loading = true
	setStatus(statusLabel, "Loading vows...", THEME.Gold)

	local ok, payload = pcall(function()
		return getBindingVows:InvokeServer()
	end)

	loading = false

	if ok and typeof(payload) == "table" then
		currentPayload = payload
		refreshOpenBadge()
		setStatus(statusLabel, "", THEME.Gold)
		return payload
	end

	warn("[BitKaisenBindingVowsUI] Failed to load vows:", payload)

	currentPayload = {
		ActiveVows = {},
		BrokenBindingVows = {},
		CustomVows = {},
		CustomOptions = {
			Sacrifices = {},
			Rewards = {},
			Severities = {},
		},
		Vows = {},
	}

	refreshOpenBadge()
	setStatus(statusLabel, "Could not load vows. Check GetBindingVows.", THEME.Bad)
	return currentPayload
end

local function layout()
	local v = viewport()
	local small = isSmallScreen()

	local scaleX = (v.X - MOBILE_WINDOW_MARGIN_X) / BASE_WINDOW_WIDTH
	local scaleY = (v.Y - MOBILE_WINDOW_MARGIN_Y) / BASE_WINDOW_HEIGHT
	local responsiveScale = math.clamp(math.min(scaleX, scaleY, 1), 0.34, 1)

	window.Size = UDim2.fromOffset(BASE_WINDOW_WIDTH, BASE_WINDOW_HEIGHT)
	window.Position = UDim2.new(0.5, 0, 0.5, 0)
	windowScale.Scale = responsiveScale

	if small then
		openButton.Size = UDim2.new(0, 66, 0, 30)
		openButton.Position = UDim2.new(1, -58, 0, 14)
	else
		openButton.Size = UDim2.new(0, 74, 0, 32)
		openButton.Position = UDim2.new(1, -70, 0, 18)
	end
end

local function updateTabs()
	if currentTab == "Custom" then
		customTab.BackgroundColor3 = THEME.Purple
		presetTab.BackgroundColor3 = THEME.Button
	else
		customTab.BackgroundColor3 = THEME.Button
		presetTab.BackgroundColor3 = THEME.Purple
	end
end

