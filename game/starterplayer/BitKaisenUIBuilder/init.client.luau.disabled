	minus.ZIndex = 56
	minus.Parent = controls
	addCorner(minus, 8)
	addStroke(minus, THEME.Stroke, 1)

	local valueLabel = Instance.new("TextLabel")
	valueLabel.Size = UDim2.new(0, 42, 0, 34)
	valueLabel.Position = UDim2.new(0, 38, 0, 0)
	valueLabel.BackgroundTransparency = 1
	valueLabel.TextColor3 = THEME.Gold
	valueLabel.TextSize = 13
