local function applyRelationshipResponsiveLayout()
	local viewport = getViewportSize()
	local mobile = viewport.X < 900
	local small = viewport.X < 520

	if mobile then
		window.Size = UDim2.new(0.90, 0, 0.70, 0)
		window.Position = UDim2.new(0.5, 0, 0.48, 0)
		title.Position = UDim2.new(0, 18, 0, 12)
		title.Size = UDim2.new(1, -72, 0, 30)
		title.TextSize = small and 17 or 19
		subtitle.Position = UDim2.new(0, 18, 0, 40)
		subtitle.Size = UDim2.new(1, -72, 0, 28)
		subtitle.TextSize = small and 8 or 10
		subtitle.TextWrapped = true
		closeButton.Size = UDim2.new(0, 32, 0, 32)
		closeButton.Position = UDim2.new(1, -40, 0, 10)
		closeButton.TextSize = 16
		scroll.Position = UDim2.new(0, 12, 0, 72)
		scroll.Size = UDim2.new(1, -24, 1, -84)
		scroll.ScrollBarThickness = 4

		detailWindow.Size = UDim2.new(0.86, 0, 0.62, 0)
		detailClose.Size = UDim2.new(0, 30, 0, 30)
		detailClose.Position = UDim2.new(1, -38, 0, 10)
		detailClose.TextSize = 15
		detailName.Position = UDim2.new(0, 16, 0, 14)
		detailName.Size = UDim2.new(1, -62, 0, 26)
		detailName.TextSize = small and 16 or 18
		detailName.TextWrapped = true
		detailRole.Position = UDim2.new(0, 16, 0, 42)
		detailRole.Size = UDim2.new(1, -32, 0, 18)
		detailRole.TextSize = small and 10 or 11
		detailRole.TextWrapped = true
		detailInfo.Position = UDim2.new(0, 16, 0, 68)
		detailInfo.Size = UDim2.new(1, -32, 0, small and 96 or 104)
		detailInfo.TextSize = small and 10 or 11
		detailBody.Position = UDim2.new(0, 16, 0, small and 174 or 184)
		detailBody.Size = UDim2.new(1, -32, 1, small and -190 or -200)
		detailBody.TextSize = small and 10 or 11
	else
		window.Size = UDim2.new(0.60, 0, 0.80, 0)
		window.Position = UDim2.new(0.5, 0, 0.54, 0)
		title.Position = UDim2.new(0, 28, 0, 16)
		title.Size = UDim2.new(1, -100, 0, 38)
		title.TextSize = 24
		subtitle.Position = UDim2.new(0, 29, 0, 52)
		subtitle.Size = UDim2.new(1, -100, 0, 18)
		subtitle.TextSize = 12
		closeButton.Size = UDim2.new(0, 40, 0, 40)
		closeButton.Position = UDim2.new(1, -54, 0, 16)
		closeButton.TextSize = 20
		scroll.Position = UDim2.new(0, 27, 0, 82)
		scroll.Size = UDim2.new(1, -54, 1, -96)
		scroll.ScrollBarThickness = 5

		detailWindow.Size = UDim2.new(0, 520, 0, 430)
		detailClose.Size = UDim2.new(0, 36, 0, 36)
		detailClose.Position = UDim2.new(1, -48, 0, 12)
		detailClose.TextSize = 18
		detailName.Position = UDim2.new(0, 26, 0, 20)
		detailName.Size = UDim2.new(1, -85, 0, 34)
		detailName.TextSize = 24
		detailRole.Position = UDim2.new(0, 26, 0, 56)
		detailRole.Size = UDim2.new(1, -60, 0, 20)
		detailRole.TextSize = 13
		detailInfo.Position = UDim2.new(0, 26, 0, 90)
		detailInfo.Size = UDim2.new(1, -52, 0, 86)
