local function applyEventChoiceResponsiveLayout()
	local camera = workspace.CurrentCamera
	local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
	local isMobile = viewport.X < 900
	local isSmallMobile = viewport.X < 520

	if isMobile then
		eventChoiceWindow.Size = UDim2.new(0.90, 0, 0.68, 0)
		eventChoiceWindow.Position = UDim2.new(0.5, 0, 0.48, 0)
		eventChoiceTitle.Size = UDim2.new(1, -28, 0, isSmallMobile and 22 or 26)
		eventChoiceTitle.Position = UDim2.new(0, 14, 0, 12)
		eventChoiceTitle.TextSize = isSmallMobile and 15 or 18
		eventChoiceBody.Size = UDim2.new(1, -28, 0, isSmallMobile and 84 or 100)
		eventChoiceBody.Position = UDim2.new(0, 14, 0, isSmallMobile and 42 or 48)
		eventChoiceBody.TextSize = isSmallMobile and 10 or 12
		eventChoiceOptions.Size = UDim2.new(1, -28, 1, isSmallMobile and -138 or -160)
		eventChoiceOptions.Position = UDim2.new(0, 14, 0, isSmallMobile and 132 or 150)
	else
		eventChoiceWindow.Size = UDim2.new(0, 560, 0, 420)
		eventChoiceWindow.Position = UDim2.new(0.5, 0, 0.54, 0)
		eventChoiceTitle.Size = UDim2.new(1, -56, 0, 32)
		eventChoiceTitle.Position = UDim2.new(0, 28, 0, 24)
		eventChoiceTitle.TextSize = 24
		eventChoiceBody.Size = UDim2.new(1, -70, 0, 120)
		eventChoiceBody.Position = UDim2.new(0, 35, 0, 72)
		eventChoiceBody.TextSize = 15
		eventChoiceOptions.Size = UDim2.new(1, -70, 0, 184)
		eventChoiceOptions.Position = UDim2.new(0, 35, 0, 204)
	end
end

applyEventChoiceResponsiveLayout()
if workspace.CurrentCamera then
	workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(applyEventChoiceResponsiveLayout)
end

local function clearCards(scroll)
	for _, child in ipairs(scroll:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end
end

local function closeModal()
	if modalBusy then return end
	modalBusy = true

	TweenService:Create(overlayPanel, TweenInfo.new(0.2), { BackgroundTransparency = 1 }):Play()

	local activeWindow = nil
	if missionWindow.Visible then activeWindow = missionWindow
	elseif activityWindow.Visible then activeWindow = activityWindow
	elseif settingsWindow.Visible then activeWindow = settingsWindow
	end

	if not activeWindow then
		missionWindow.Visible = false
		activityWindow.Visible = false
		settingsWindow.Visible = false
		overlayPanel.Visible = false
		modalBusy = false
		return
	end

	local closeTween = TweenService:Create(activeWindow, TweenInfo.new(0.2), {
		Position = UDim2.new(0.5, 0, 0.55, 0),
		BackgroundTransparency = 1
	})
	closeTween:Play()
	closeTween.Completed:Wait()

	missionWindow.Visible = false
	activityWindow.Visible = false
	settingsWindow.Visible = false
	overlayPanel.Visible = false
	modalBusy = false
end

local function openModal(window)
	if modalBusy then return end
	missionWindow.Visible = false
	activityWindow.Visible = false
	settingsWindow.Visible = false

	overlayPanel.Visible = true
	window.Visible = true
	window.Position = UDim2.new(0.5, 0, 0.55, 0)
	window.BackgroundTransparency = 1

	TweenService:Create(overlayPanel, TweenInfo.new(0.3), { BackgroundTransparency = 0.5 }):Play()
	TweenService:Create(window, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, 0, 0.5, 0),
		BackgroundTransparency = 0
	}):Play()
end

