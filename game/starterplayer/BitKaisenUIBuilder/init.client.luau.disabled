	refreshActivityList()
end)

closeMissionBtn.MouseButton1Click:Connect(function() closeModal() end)
closeActivityBtn.MouseButton1Click:Connect(function() closeModal() end)
closeSettingsBtn.MouseButton1Click:Connect(function() closeModal() end)

settingsButton.MouseButton1Click:Connect(function()
	rebuildSettingsWindow()
	openModal(settingsWindow)
end)

popupContinue.MouseButton1Click:Connect(function() closeCurrentPopup() end)

ageClickBusy = false
ageUpButton.MouseButton1Click:Connect(function()
	if ageClickBusy then return end
	ageClickBusy = true
	eventChoiceOpen = false
	if eventChoiceOverlay then eventChoiceOverlay.Visible = false end
	setAgeButtonBlocked(false)
	updateLifeEvent:FireServer("AgeUp")
	task.delay(0.35, function()
		ageClickBusy = false
		setAgeButtonBlocked(false)
	end)
end)

relateBtn.MouseButton1Click:Connect(function()
	-- Relationships are handled by BitKaisenRelationshipsUI.
end)

assetsBtn.MouseButton1Click:Connect(function()
	-- Assets are handled by BitKaisenAssetsUI.
end)

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(purchasedPlayer, purchasedPassId, wasPurchased)
	if purchasedPlayer ~= player then return end
	if purchasedPassId ~= VIP_SORCERER_PASS_ID then return end
	if wasPurchased and settingsWindow.Visible then
		task.delay(0.4, function() rebuildSaveSlotsWindow() end)
	end
end)

showMajorPopup.OnClientEvent:Connect(function(data)
	queueMajorPopup(data)
end)

-- Mission situations are handled by the dedicated BitKaisenMissionSituationUI LocalScript.
showMissionSituation.OnClientEvent:Connect(function(data)
	setAgeButtonBlocked(false)
end)

updateLifeEvent.OnClientEvent:Connect(function(updatedStats, logMessage, forceResetLog)
	refreshUI(updatedStats, logMessage, forceResetLog)

	if updatedStats and updatedStats.Alive == false then
		actionRow.Visible = false
		navPanel.Visible = false
		lastLifeWasDead = true
		pushLogLine("")
		pushLogLine("<font color='#404050'><b>[ SYSTEM ]</b></font>")
		pushLogLine("You have died. Awaiting Legacy processing...")
	end
end)	
