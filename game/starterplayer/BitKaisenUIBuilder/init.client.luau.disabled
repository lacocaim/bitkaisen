local function getShopAccent(categoryName)
	if categoryName == "Featured" then return THEME.Gold
	elseif categoryName == "Boosts" then return THEME.Purple
	elseif categoryName == "Currency" then return THEME.Green
	elseif categoryName == "Passes" then return THEME.Blue
	end
	return THEME.Red
end

showGiftStatusPopup = function(success, titleText, bodyText)
	local shade = Instance.new("Frame")
	shade.Name = "GiftStatusPopup"
	shade.Size = UDim2.new(1, 0, 1, 0)
	shade.BackgroundTransparency = 1
	shade.ZIndex = 8000
	shade.Parent = gui

	local card = Instance.new("Frame")
	card.Size = UDim2.new(0, 360, 0, 132)
	card.Position = UDim2.new(0.5, -180, 0.5, -66)
	card.BackgroundColor3 = success and Color3.fromRGB(22, 75, 42) or Color3.fromRGB(92, 24, 34)
	card.BorderSizePixel = 0
	card.ZIndex = 8001
	card.Parent = shade
	addCorner(card, 10)
	addStroke(card, success and THEME.Green or THEME.Red, 2)

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -28, 0, 28)
	title.Position = UDim2.new(0, 14, 0, 18)
	title.BackgroundTransparency = 1
	title.TextColor3 = THEME.Text
	title.TextSize = 18
	title.Font = Enum.Font.GothamBlack
	title.Text = tostring(titleText or (success and "GIFT READY" or "GIFT ERROR"))
	title.ZIndex = 8002
	title.Parent = card

	local body = Instance.new("TextLabel")
	body.Size = UDim2.new(1, -36, 0, 56)
	body.Position = UDim2.new(0, 18, 0, 58)
	body.BackgroundTransparency = 1
	body.TextColor3 = THEME.Text
	body.TextSize = 13
	body.Font = Enum.Font.GothamMedium
	body.TextWrapped = true
	body.Text = tostring(bodyText or "")
	body.ZIndex = 8002
	body.Parent = card

	task.delay(2.2, function()
		if shade and shade.Parent then shade:Destroy() end
	end)
end

promptGiftRecipient = function(item)
	local overlay = Instance.new("Frame")
	overlay.Name = "GiftRecipientPrompt"
	overlay.Size = UDim2.new(1, 0, 1, 0)
	overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	overlay.BackgroundTransparency = 0.42
	overlay.ZIndex = 5000
	overlay.Parent = gui

	local box = Instance.new("Frame")
	box.Size = UDim2.new(0, 360, 0, 190)
	box.Position = UDim2.new(0.5, -180, 0.5, -95)
	box.BackgroundColor3 = THEME.Panel
	box.BorderSizePixel = 0
	box.ZIndex = 5001
	box.Parent = overlay
	addCorner(box, 10)
	addStroke(box, THEME.Stroke, 1)

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -32, 0, 28)
	title.Position = UDim2.new(0, 16, 0, 16)
	title.BackgroundTransparency = 1
	title.TextColor3 = THEME.Gold
	title.TextSize = 18
	title.Font = Enum.Font.GothamBlack
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Text = tostring(item.Name or "Gift")
	title.ZIndex = 5002
	title.Parent = box

	local note = Instance.new("TextLabel")
	note.Size = UDim2.new(1, -32, 0, 20)
	note.Position = UDim2.new(0, 16, 0, 44)
	note.BackgroundTransparency = 1
	note.TextColor3 = THEME.SubText
	note.TextSize = 11
	note.Font = Enum.Font.GothamMedium
	note.TextXAlignment = Enum.TextXAlignment.Left
	note.Text = "Type the receiver's Roblox username. Gifts cannot be sent to yourself."
	note.ZIndex = 5002
	note.Parent = box

	local input = Instance.new("TextBox")
	input.Size = UDim2.new(1, -32, 0, 42)
	input.Position = UDim2.new(0, 16, 0, 72)
	input.BackgroundColor3 = THEME.Panel2
	input.BorderSizePixel = 0
	input.PlaceholderText = "Recipient Roblox username"
	input.Text = ""
	input.TextColor3 = THEME.Text
	input.PlaceholderColor3 = THEME.SubText
	input.TextSize = 14
	input.Font = Enum.Font.GothamBold
	input.ClearTextOnFocus = false
	input.ZIndex = 5002
	input.Parent = box
	addCorner(input, 8)
	addStroke(input, THEME.Stroke, 1)

	local cancel = Instance.new("TextButton")
	cancel.Size = UDim2.new(0.48, -8, 0, 40)
	cancel.Position = UDim2.new(0, 16, 1, -56)
	cancel.BackgroundColor3 = THEME.Panel2
	cancel.BorderSizePixel = 0
	cancel.TextColor3 = THEME.Text
	cancel.TextSize = 13
	cancel.Font = Enum.Font.GothamBlack
	cancel.Text = "CANCEL"
	cancel.ZIndex = 5002
	cancel.Parent = box
	addCorner(cancel, 8)

	local buy = cancel:Clone()
	buy.Position = UDim2.new(0.52, 0, 1, -56)
	buy.BackgroundColor3 = THEME.Purple
	buy.Text = "GIFT"
	buy.Parent = box

	cancel.MouseButton1Click:Connect(function()
		overlay:Destroy()
	end)

	buy.MouseButton1Click:Connect(function()
		local nameText = tostring(input.Text or ""):gsub("^%s+", ""):gsub("%s+$", "")
		if nameText == "" then
			showGiftStatusPopup(false, "GIFT ERROR", "Enter the receiver's Roblox username first.")
			return
		end
		if string.lower(nameText) == string.lower(player.Name) then
			showGiftStatusPopup(false, "GIFT ERROR", "You cannot gift this to yourself. Enter another player's Roblox username.")
			return
		end
		buy.Text = "CHECKING..."
		local ok, result = pcall(function()
			return setGiftRecipient:InvokeServer(item.RobloxId, nameText)
		end)
		if not ok or typeof(result) ~= "table" or result.Success ~= true then
			buy.Text = "GIFT"
			showGiftStatusPopup(false, "GIFT ERROR", (typeof(result) == "table" and result.Message) or "Could not set gift recipient.")
			return
		end
		overlay:Destroy()
		showGiftStatusPopup(true, "GIFT READY", "Receiver confirmed: " .. tostring(result.RecipientName or nameText) .. ". Complete the purchase to send the gift.")
		if game.PlaceId == 104206065947170 then
			ReplicatedStorage:WaitForChild("TestPurchase"):FireServer(item.Kind, item.RobloxId)
		else
			MarketplaceService:PromptProductPurchase(player, item.RobloxId)
		end
	end)

	task.defer(function()
		input:CaptureFocus()
	end)
end

promptShopProduct = function(item)
	if not item or not item.RobloxId or item.RobloxId <= 0 then
		createMenuNotice("This product needs a real Roblox product/gamepass ID before it can be purchased. Add the ID inside SHOP_PRODUCTS at the top of BitKaisenUIBuilder and match it on the server if it is a developer product.")
		return
	end
	if item.GiftPassKey then
		promptGiftRecipient(item)
		return
	end
	if game.PlaceId == 104206065947170 then
		ReplicatedStorage:WaitForChild("TestPurchase"):FireServer(item.Kind, item.RobloxId)
		return
	end
	if item.Kind == "GamePass" then
		MarketplaceService:PromptGamePassPurchase(player, item.RobloxId)
	else
		MarketplaceService:PromptProductPurchase(player, item.RobloxId)
	end
end

local function getVIPShopItem()
	for _, products in pairs(SHOP_PRODUCTS) do
		for _, item in ipairs(products) do
			if item.Id == "vip_pass" then return item end
		end
	end
	return { Id = "vip_pass", Name = "VIP Sorcerer Pass", Kind = "GamePass", RobloxId = VIP_SORCERER_PASS_ID }
end

local function promptVIPPurchase()
	promptShopProduct(getVIPShopItem())
end

