local BASE_CARD_HEIGHT = 214
local EXPANDED_CARD_HEIGHT = 430
local MOBILE_BASE_CARD_HEIGHT = 218
local MOBILE_EXPANDED_CARD_HEIGHT = 380

local FAMILY_ROLES = {
	Mother = true,
	Father = true,
	Caretaker = true,
	Sibling = true,
	Child = true,
	Ward = true,
	Student = true,
	["Late Mother"] = true,
	["Late Father"] = true,
}

local FLIRTABLE_ROLES = {
	Friend = true,
	["Best Friend"] = true,
	["Mission Partner"] = true,
}

local ROMANCE_ROLES = {
	Partner = true,
	Spouse = true,
}

local isOpen = false
local detailOpen = false
local busyAction = false
local pendingRefresh = false
local refreshStamp = 0
local openingWindow = false
local refreshInProgress = false
local lastOpenClick = 0
local expandedRelationshipId = nil
local cardRefs = {}
local currentRelationships = {}
local canBrainTransplant = false
local canNameChildren = false
local scroll = nil
local livingPage = 1
local deceasedPage = 1
local refreshRelationships

local function getViewportSize()
	local camera = workspace.CurrentCamera
	return camera and camera.ViewportSize or Vector2.new(1280, 720)
end

local function isMobileViewport()
	local viewport = getViewportSize()
	return viewport.X < 900 or (UserInputService.TouchEnabled and viewport.Y > viewport.X)
end

local function isSmallMobileViewport()
	local viewport = getViewportSize()
	return viewport.X < 520
end

local function mobileScale(defaultValue, mobileValue, smallValue)
	if isSmallMobileViewport() then
		return smallValue or mobileValue or defaultValue
	end
	if isMobileViewport() then
		return mobileValue or defaultValue
	end
	return defaultValue
end

local function addCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
	return corner
end

local function addStroke(parent, color, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness or 1
	stroke.Parent = parent
	return stroke
end

local function clampPercent(value)
	return math.clamp(tonumber(value) or 0, 0, 100)
end

local function lighten(color, add)
	return Color3.fromRGB(
		math.clamp(math.floor(color.R * 255 + add), 0, 255),
		math.clamp(math.floor(color.G * 255 + add), 0, 255),
		math.clamp(math.floor(color.B * 255 + add), 0, 255)
	)
end

local function clearRelationshipContent()
	for _, child in ipairs(scroll:GetChildren()) do
		if child:IsA("Frame") or child:IsA("TextLabel") then
			child:Destroy()
		end
	end
end

local function roleColor(role)
	if role == "Mother" or role == "Father" or role == "Sibling" or role == "Caretaker" or role == "Child" or role == "Ward" or role == "Spouse" or role == "Late Mother" or role == "Late Father" then
		return COLORS.Gold
	elseif role == "Teacher" then
		return COLORS.Trust
	elseif role == "Rival" then
		return Color3.fromRGB(255, 90, 90)
	elseif role == "Partner" then
		return COLORS.Romance
	elseif role == "Ex-Spouse" then
		return COLORS.Bad
	elseif role == "Best Friend" or role == "Friend" or role == "Classmate" then
		return COLORS.Bond
	elseif role == "Mission Partner" then
		return COLORS.Purple
	end

	return Color3.fromRGB(190, 190, 205)
end

local function getRelationshipAge(relationship)
	if relationship.Age ~= nil then
		return tonumber(relationship.Age) or 0
	end

	return tonumber(relationship.DisplayAge) or tonumber(relationship.EstimatedAge) or 0
end

local function getRelationshipGender(relationship)
	local gender = tostring(relationship.Gender or "Unknown")

	if gender == "Male" or gender == "Female" then
		return gender
	end

	return "Unknown"
end

local function getRelationshipGrade(relationship)
	return tostring(relationship.Grade or relationship.SorcererGrade or "Non-Sorcerer")
end

local function getRelationshipTechnique(relationship)
	return tostring(relationship.CursedTechnique or "None")
end

local function getRelationshipCE(relationship)
	return tonumber(relationship.CursedEnergy) or 0
end

local function getRelationshipTraits(relationship)
	if not relationship then
		return "None"
	end

	if relationship.TraitSummary and relationship.TraitSummary ~= "" then
		return tostring(relationship.TraitSummary)
	end

	if type(relationship.Traits) == "table" and #relationship.Traits > 0 then
		local names = {}
		for _, trait in ipairs(relationship.Traits) do
			if type(trait) == "table" then
				table.insert(names, tostring(trait.Name or trait.Id or "Unknown"))
			else
				local text = tostring(trait)
				text = text:gsub("_", " ")
				text = text:gsub("(%a)([%w_']*)", function(first, rest)
					return string.upper(first) .. string.lower(rest)
				end)
				table.insert(names, text)
			end
		end
		return table.concat(names, ", ")
	end

	return "None"
end

local function getPersonality(relationship)
	return tostring(relationship.Personality or relationship.Trait or "No clear personality read yet.")
end

local function getBackground(relationship)
	if relationship.Background and relationship.Background ~= "" then
		return tostring(relationship.Background)
	end

	local role = tostring(relationship.Role or "Unknown")
	local name = tostring(relationship.Name or "This person")

	if role == "Mother" or role == "Father" or role == "Caretaker" then
		return name .. " helped shape your early life and family history."
	elseif role == "Sibling" then
		return name .. " grew up connected to the same family pressure as you."
	elseif role == "Child" then
		return name .. " is part of your legacy and may inherit pieces of your world. Custody: " .. tostring(relationship.Custody or "With You") .. "."
	elseif role == "Ward" then
		return name .. " was rescued from a curse incident and is growing under your protection."
	elseif role == "Student" then
		return name .. " trains under your dojo and represents your clan's future."
	elseif role == "Teacher" then
		return name .. " watches your growth as a sorcerer and can influence your future."
	elseif role == "Rival" then
		return name .. " measures their growth against yours and may become a problem later."
	elseif role == "Partner" or role == "Spouse" then
		return name .. " is tied closely to your personal life beyond missions and curses."
	elseif role == "Mission Partner" then
		return name .. " has worked beside you during dangerous assignments."
	elseif role == "Late Mother" or role == "Late Father" then
		return name .. " is part of the bloodline memory you inherited."
	end

	return name .. " is one of the people connected to your current life."
end

local function canShowRomanceBar(relationship)
	local role = tostring(relationship.Role or "")

	if FAMILY_ROLES[role] then
		return false
	end

	if role == "Teacher" or role == "Rival" or role == "Observer" then
		return false
	end

	if ROMANCE_ROLES[role] then
		return true
	end

	if FLIRTABLE_ROLES[role] and (relationship.Romance or 0) > 0 then
		return true
	end

	return false
end

local function getStatusLine(relationship)
	local role = tostring(relationship.Role or "Unknown")
	local status = tostring(relationship.Status or "Neutral")
	local age = getRelationshipAge(relationship)
	local gender = getRelationshipGender(relationship)
	local line = "Status: " .. status

	if gender ~= "Unknown" then
		line = line .. " • " .. gender
	end

	if age > 0 then
		line = line .. " • Age " .. tostring(age)
	end

	if role == "Child" then
		line = line .. " • Custody: " .. tostring(relationship.Custody or "With You")
		if relationship.CustodyParentName and relationship.CustodyParentName ~= "" then
			line = line .. " (" .. tostring(relationship.CustodyParentName) .. ")"
		end
	elseif role == "Partner" then
		line = line .. " • Dating " .. tostring(relationship.YearsDating or 0) .. " years"
	elseif role == "Spouse" then
		line = line .. " • Married " .. tostring(relationship.YearsMarried or 0) .. " years"
	elseif role == "Ex-Spouse" then
		line = line .. " • Divorced " .. tostring(relationship.YearsDivorced or 0) .. " years"
	elseif (relationship.YearsKnown or 0) > 0 then
		line = line .. " • Known " .. tostring(relationship.YearsKnown or 0) .. " years"
	end

	local occupation = tostring(relationship.Occupation or relationship.FamilyCareer or "")
	if occupation ~= "" and occupation ~= "Undecided" and occupation ~= "None" then
		line = line .. " • " .. occupation
	end

	if relationship.MarriedIndependently == true then
		local childCount = tonumber(relationship.IndependentChildCount) or (typeof(relationship.IndependentChildren) == "table" and #relationship.IndependentChildren or 0)
		line = line .. " • Own family"
		if childCount > 0 then
			line = line .. " (" .. tostring(childCount) .. " child" .. (childCount == 1 and "" or "ren") .. ")"
		end
	end

	return line
end

local function addMurderAction(actions, relationship)
	local role = tostring(relationship and relationship.Role or "")
	local blockedRoles = {
		Child = true,
		Ward = true,
		Mother = true,
		Father = true,
		Caretaker = true,
		Sibling = true,
		Teacher = true,
		Student = true,
	}

	if relationship and relationship.Alive ~= false and not blockedRoles[role] then
		table.insert(actions, { Id = "murder_relationship", Text = "Murder", Confirm = true })
	end
	return actions
end

local function getActionsForRelationship(relationship)
	local role = tostring(relationship.Role or "")

	if relationship.Alive == false then
		local actions = {
			{ Id = "forget_relationship", Text = "Forget", Confirm = true },
		}
		if canBrainTransplant then
			table.insert(actions, { Id = "brain_transplant", Text = "Transplant", Confirm = true })
		end
		return actions
	end

	if role == "Notable Sorcerer" then
		return addMurderAction({
			{ Id = "talk", Text = "Talk" },
			{ Id = "compliment", Text = "Compliment" },
			{ Id = "train_together", Text = "Train" },
			{ Id = "pair_mission", Text = "Mission" },
		}, relationship)
	end

	if role == "Ward" then
		local actions = {
			{ Id = "talk", Text = "Talk" },
			{ Id = "encourage_child", Text = "Encourage" },
			{ Id = "protect_child", Text = "Protect" },
		}

		if (relationship.Age or 0) >= 8 then
			table.insert(actions, { Id = "train_child", Text = "Train CE" })
		end

		if (relationship.Age or 0) >= 12 and relationship.DojoStudent ~= true then
			table.insert(actions, { Id = "recruit_dojo", Text = "Recruit Dojo" })
		end

		return actions
	end

	if role == "Child" then
		local actions = {
			{ Id = "teach_child", Text = "Teach" },
			{ Id = "protect_child", Text = "Protect" },
			{ Id = "encourage_child", Text = "Encourage" },
			{ Id = "take_over_child", Text = "Take Over", Confirm = true },
			{ Id = "disown_child", Text = "Disown", Confirm = true },
		}

		if relationship.Custody == "Shared" or relationship.Custody == "With Ex-Spouse" then
			table.insert(actions, { Id = "custody_visit", Text = "Custody Visit" })
		end

		if (relationship.Age or 0) >= 8 then
			table.insert(actions, { Id = "train_child", Text = "Train CE" })
		end

		return actions
	end

	if role == "Student" then
		return {
			{ Id = "talk", Text = "Talk" },
			{ Id = "encourage_child", Text = "Encourage" },
			{ Id = "train_together", Text = "Train" },
			{ Id = "ask_advice", Text = "Guide" },
		}
	end

	if role == "Mother" or role == "Father" or role == "Caretaker" or role == "Sibling" then
		return {
			{ Id = "talk", Text = "Talk" },
			{ Id = "family_time", Text = "Family Time" },
			{ Id = "ask_advice", Text = "Ask Advice" },
			{ Id = "apologize", Text = "Apologize" },
		}
	end

	if role == "Teacher" then
		return {
			{ Id = "ask_advice", Text = "Ask Advice" },
			{ Id = "train_together", Text = "Train" },
			{ Id = "mentor_session", Text = "Mentor Session" },
			{ Id = "ask_recommendation", Text = "Recommendation" },
		}
	end

	if role == "Rival" then
		return addMurderAction({
			{ Id = "talk", Text = "Talk" },
			{ Id = "spar", Text = "Spar" },
			{ Id = "challenge", Text = "Challenge" },
			{ Id = "acknowledge", Text = "Acknowledge" },
		}, relationship)
	end

	if role == "Classmate" then
		return addMurderAction({
			{ Id = "talk", Text = "Talk" },
			{ Id = "study_together", Text = "Study" },
			{ Id = "train_together", Text = "Train" },
			{ Id = "spend_time", Text = "Hang Out" },
		}, relationship)
	end

	if role == "Friend" or role == "Best Friend" then
		local actions = {
			{ Id = "talk", Text = "Talk" },
			{ Id = "spend_time", Text = "Hang Out" },
			{ Id = "deep_talk", Text = "Open Up" },
			{ Id = "train_together", Text = "Train" },
			{ Id = "flirt", Text = "Flirt" },
			{ Id = "remove_relationship", Text = "Remove", Confirm = true },
		}

		if (relationship.Bond or 0) >= 45 and (relationship.Trust or 0) >= 35 and (relationship.Romance or 0) >= 25 then
			table.insert(actions, { Id = "ask_out", Text = "Ask Out" })
		end

		return addMurderAction(actions, relationship)
	end

	if role == "Mission Partner" then
		local actions = {
			{ Id = "talk", Text = "Talk" },
			{ Id = "train_together", Text = "Train" },
			{ Id = "pair_mission", Text = "Paired Mission" },
			{ Id = "deep_talk", Text = "Open Up" },
			{ Id = "flirt", Text = "Flirt" },
			{ Id = "remove_relationship", Text = "Remove", Confirm = true },
		}

		if (relationship.Bond or 0) >= 45 and (relationship.Trust or 0) >= 35 and (relationship.Romance or 0) >= 25 then
			table.insert(actions, { Id = "ask_out", Text = "Ask Out" })
		end

		return addMurderAction(actions, relationship)
	end

	if role == "Partner" then
		return addMurderAction({
			{ Id = "spend_time", Text = "Spend Time" },
			{ Id = "deep_talk", Text = "Open Up" },
			{ Id = "give_gift", Text = "Gift" },
			{ Id = "propose", Text = "Propose" },
			{ Id = "remove_relationship", Text = "Break Up", Confirm = true },
		}, relationship)
	end

	if role == "Spouse" then
		return addMurderAction({
			{ Id = "spend_time", Text = "Spend Time" },
			{ Id = "deep_talk", Text = "Open Up" },
			{ Id = "give_gift", Text = "Gift" },
			{ Id = "start_family", Text = "Start Family" },
			{ Id = "adopt_child", Text = "Adopt" },
			{ Id = "divorce", Text = "Divorce", Confirm = true },
		}, relationship)
	end

	if role == "Ex-Spouse" then
		return addMurderAction({
			{ Id = "talk", Text = "Talk" },
			{ Id = "apologize", Text = "Apologize" },
			{ Id = "discuss_custody", Text = "Custody" },
			{ Id = "remove_relationship", Text = "Remove", Confirm = true },
		}, relationship)
	end

	return addMurderAction({
		{ Id = "talk", Text = "Talk" },
		{ Id = "spend_time", Text = "Hang Out" },
		{ Id = "ask_advice", Text = "Ask Advice" },
		{ Id = "remove_relationship", Text = "Remove", Confirm = true },
	}, relationship)
end

