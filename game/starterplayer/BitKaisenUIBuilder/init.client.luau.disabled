	plus.TextColor3 = THEME.Text
	plus.TextSize = 16
	plus.Font = Enum.Font.GothamBlack
	plus.Text = "+"
	plus.AutoButtonColor = false
	plus.ZIndex = 56
	plus.Parent = controls
	addCorner(plus, 8)
	addStroke(plus, THEME.Stroke, 1)

	local function setVolume(newValue)
		currentSettings[key] = math.clamp(newValue, 0, 1)
		valueLabel.Text = tostring(math.floor(currentSettings[key] * 100 + 0.5)) .. "%"
		updateSettingsEvent:FireServer(key, currentSettings[key])
	end

	minus.MouseButton1Click:Connect(function() setVolume((currentSettings[key] or 0) - 0.1) end)
	plus.MouseButton1Click:Connect(function() setVolume((currentSettings[key] or 0) + 0.1) end)
end

