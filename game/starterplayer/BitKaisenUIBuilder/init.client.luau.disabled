notificationLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
notificationLayout.Parent = notificationHolder

local activeNotifications = {}

local function trimNotifications()
	while #activeNotifications > 3 do
		local oldest = table.remove(activeNotifications, 1)
		if oldest and oldest.Parent then
			oldest:Destroy()
		end
	end
end

local function makeStatNotification(text, isPositive)
	local card = Instance.new("Frame")
	card.Size = UDim2.new(1, 0, 0, 38)
	card.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
	card.BackgroundTransparency = 1
	card.BorderSizePixel = 0
	card.ZIndex = 201
	card.Parent = notificationHolder
	addCorner(card, 8)

	table.insert(activeNotifications, card)
	trimNotifications()

	local stroke = addStroke(card, isPositive and Color3.fromRGB(70, 190, 110) or Color3.fromRGB(210, 70, 70))
	stroke.Transparency = 1

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -20, 1, 0)
	label.Position = UDim2.new(0, 10, 0, 0)
	label.BackgroundTransparency = 1
	label.TextColor3 = isPositive and Color3.fromRGB(120, 240, 160) or Color3.fromRGB(255, 115, 115)
	label.TextTransparency = 1
	label.TextSize = 14
	label.Font = Enum.Font.GothamBold
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = text
	label.ZIndex = 202
	label.Parent = card

	card.Position = UDim2.new(0, 35, 0, 0)

	TweenService:Create(card, TweenInfo.new(0.2), {
		BackgroundTransparency = 0,
		Position = UDim2.new(0, 0, 0, 0)
	}):Play()
	TweenService:Create(stroke, TweenInfo.new(0.2), { Transparency = 0 }):Play()
	TweenService:Create(label, TweenInfo.new(0.2), { TextTransparency = 0 }):Play()

	task.delay(2, function()
		if not card or not card.Parent then return end
		TweenService:Create(card, TweenInfo.new(0.25), {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 35, 0, 0)
		}):Play()
		TweenService:Create(stroke, TweenInfo.new(0.25), { Transparency = 1 }):Play()
		TweenService:Create(label, TweenInfo.new(0.25), { TextTransparency = 1 }):Play()
		task.delay(0.3, function()
			for index, notification in ipairs(activeNotifications) do
				if notification == card then
					table.remove(activeNotifications, index)
					break
				end
			end
			if card then card:Destroy() end
		end)
	end)
end

local function copyStats(stats)
	if not stats then return nil end
	return {
		Health = stats.Health or 0,
		Happiness = stats.Happiness or 0,
		Smarts = stats.Smarts or 0,
		CursedEnergy = stats.CursedEnergy or 0,
		Money = stats.Money or 0,
		Reputation = stats.Reputation or 0,
		TeacherRecommendations = stats.TeacherRecommendations or 0,
		TechniqueMastery = stats.TechniqueMastery or 0,
		Looks = stats.Looks or 50,
		Strength = stats.Strength or 0
	}
end

local previousStats = nil
local currentStats = nil

local function showStatChanges(oldStats, newStats)
	if not oldStats or not newStats then return end
	local tracked = {
		{ Key = "Health", Label = "Health" },
		{ Key = "Happiness", Label = "Happiness" },
		{ Key = "Smarts", Label = "Smarts" },
		{ Key = "Looks", Label = "Looks" },
		{ Key = "Strength", Label = "Strength" },
		{ Key = "CursedEnergy", Label = "CE Reserves" },
		{ Key = "Money", Label = "Money", Prefix = "$" },
		{ Key = "Reputation", Label = "Reputation" },
		{ Key = "TeacherRecommendations", Label = "Recommendation" },
		{ Key = "TechniqueMastery", Label = "Technique Mastery" }
	}
	for _, data in ipairs(tracked) do
		local before = oldStats[data.Key] or 0
		local after = newStats[data.Key] or 0
		local diff = after - before
		if diff ~= 0 then
			local sign = diff > 0 and "+" or "-"
			local amount = math.abs(diff)
			local valueText = data.Prefix and (sign .. data.Prefix .. tostring(amount)) or (sign .. tostring(amount))
			makeStatNotification(valueText .. " " .. data.Label, diff > 0)
		end
	end
end

