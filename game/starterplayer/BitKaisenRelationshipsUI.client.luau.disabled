	local pill = Instance.new("TextLabel")
	pill.Size = UDim2.new(0, mobile and math.max(34, math.floor((width or 90) * 0.42)) or width, 0, mobile and 20 or 24)
	pill.BackgroundColor3 = Color3.fromRGB(25, 25, 34)
	pill.BorderSizePixel = 0
	pill.TextColor3 = color
	pill.TextSize = small and 7 or (mobile and 8 or 11)
