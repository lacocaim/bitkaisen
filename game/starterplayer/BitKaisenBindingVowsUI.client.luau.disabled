local function getPresetButtonState(vow)
	if vow.Owned == true then
		if pendingBreakPresetId == vow.Id then
			return "CONFIRM BREAK", THEME.RedDark, true
		end

		return "BREAK VOW", THEME.RedDark, true
	end

	if vow.Broken == true then
		return "BROKEN", THEME.ButtonDisabled, false
	end

	if vow.CanMake == true then
		if pendingMakePresetId == vow.Id then
			return "CONFIRM VOW", THEME.RedDark, true
		end

		return "MAKE VOW", THEME.Purple, true
	end

	return "LOCKED", THEME.ButtonDisabled, false
end

local function makeVowCard(vow, index, isCustom)
	local owned = vow.Owned == true
	local broken = vow.Broken == true
	local canMake = vow.CanMake == true

	local buttonText
	local buttonColor
	local buttonActive

	if isCustom then
		if owned then
			if pendingBreakCustomId == vow.Id then
				buttonText = "CONFIRM BREAK"
				buttonColor = THEME.RedDark
				buttonActive = true
			else
				buttonText = "BREAK VOW"
				buttonColor = THEME.RedDark
				buttonActive = true
			end
		elseif broken then
			buttonText = "BROKEN"
			buttonColor = THEME.ButtonDisabled
			buttonActive = false
		else
			buttonText = "SIGNED"
			buttonColor = THEME.ButtonDisabled
			buttonActive = false
		end
	else
		buttonText, buttonColor, buttonActive = getPresetButtonState(vow)
	end

	local card = Instance.new("Frame")
	card.Name = (isCustom and "CustomVowCard_" or "PresetVowCard_") .. tostring(vow.Id or index)
	card.Size = UDim2.new(1, -6, 0, 202)
	card.BackgroundColor3 = owned and THEME.CardGreen or (broken and THEME.CardRed or THEME.Card)
	card.BorderSizePixel = 0
	card.ZIndex = content.ZIndex + 1
	card.Parent = content
	addCorner(card, 11)
	addStroke(card, owned and THEME.Green or (broken and THEME.Bad or THEME.StrokeSoft), owned and 2 or 1, 0)

	local title = makeText(card, "Name", tostring(vow.Name or "Binding Vow"), 16, owned and THEME.Green or (broken and THEME.Bad or THEME.Text), true)
	title.Size = UDim2.new(1, -178, 0, 24)
	title.Position = UDim2.new(0, 14, 0, 12)

	local req = Instance.new("TextLabel")
	req.Name = "Requirement"
	req.BackgroundColor3 = Color3.fromRGB(42, 34, 22)
	req.BorderSizePixel = 0
	req.Text = tostring(vow.RequirementText or "No requirement")
	req.TextColor3 = THEME.Gold
	req.TextSize = 10
	req.Font = Enum.Font.GothamBold
	req.TextXAlignment = Enum.TextXAlignment.Left
	req.TextYAlignment = Enum.TextYAlignment.Center
	req.TextWrapped = true
	req.ZIndex = card.ZIndex + 2
	req.Parent = card
	req.Size = UDim2.new(1, -178, 0, 24)
	req.Position = UDim2.new(0, 14, 0, 44)
	addCorner(req, 7)
	addStroke(req, Color3.fromRGB(82, 70, 40), 1, 0.2)
	addPadding(req, 8, 8, 0, 0)

	local desc = makeText(card, "Description", tostring(vow.Description or ""), 11, THEME.SubText, false)
	desc.Size = UDim2.new(1, -178, 0, 44)
	desc.Position = UDim2.new(0, 14, 0, 78)

	local costBox = Instance.new("Frame")
	costBox.Name = "CostBox"
	costBox.BackgroundColor3 = Color3.fromRGB(33, 21, 29)
	costBox.BorderSizePixel = 0
	costBox.ZIndex = card.ZIndex + 1
	costBox.Parent = card
	costBox.Size = UDim2.new(0.5, -26, 0, 58)
	costBox.Position = UDim2.new(0, 14, 0, 132)
	addCorner(costBox, 9)
	addStroke(costBox, Color3.fromRGB(92, 48, 58), 1, 0.15)

	local costTitle = makeText(costBox, "CostTitle", "COST", 10, THEME.Bad, true)
	costTitle.Size = UDim2.new(1, -14, 0, 14)
	costTitle.Position = UDim2.new(0, 8, 0, 6)

	local costBody = makeText(costBox, "CostBody", tostring(vow.CostText or "Unknown cost."), 10, THEME.SubText, false)
	costBody.Size = UDim2.new(1, -14, 0, 34)
	costBody.Position = UDim2.new(0, 8, 0, 21)

	local gainBox = Instance.new("Frame")
	gainBox.Name = "GainBox"
	gainBox.BackgroundColor3 = Color3.fromRGB(20, 32, 25)
	gainBox.BorderSizePixel = 0
	gainBox.ZIndex = card.ZIndex + 1
	gainBox.Parent = card
	gainBox.Size = UDim2.new(0.5, -92, 0, 58)
	gainBox.Position = UDim2.new(0.5, -4, 0, 132)
	addCorner(gainBox, 9)
	addStroke(gainBox, Color3.fromRGB(58, 92, 71), 1, 0.15)

	local gainTitle = makeText(gainBox, "GainTitle", "GAIN", 10, THEME.Green, true)
	gainTitle.Size = UDim2.new(1, -14, 0, 14)
	gainTitle.Position = UDim2.new(0, 8, 0, 6)

	local gainBody = makeText(gainBox, "GainBody", tostring(vow.BonusText or "Unknown reward."), 10, THEME.SubText, false)
	gainBody.Size = UDim2.new(1, -14, 0, 34)
	gainBody.Position = UDim2.new(0, 8, 0, 21)

	local actionButton = makeButton(card, "ActionButton", buttonText, buttonColor)
	actionButton.AnchorPoint = Vector2.new(1, 0)
	actionButton.Size = UDim2.new(0, 138, 0, 36)
	actionButton.Position = UDim2.new(1, -14, 0, 14)
	actionButton.Active = buttonActive
	actionButton.AutoButtonColor = false

	if not buttonActive then
		actionButton.TextColor3 = THEME.Muted
	end

	local stateText = owned and "ACTIVE" or (broken and "BROKEN" or (canMake and "AVAILABLE" or "LOCKED"))
	local stateColor = owned and THEME.Green or (broken and THEME.Bad or (canMake and THEME.Purple or THEME.Muted))

	local state = makeText(card, "State", stateText, 10, stateColor, true)
	state.AnchorPoint = Vector2.new(1, 0)
	state.Size = UDim2.new(0, 138, 0, 18)
	state.Position = UDim2.new(1, -14, 0, 58)
	state.TextXAlignment = Enum.TextXAlignment.Center

	local infoText
	local infoColor = THEME.SubText

	if owned then
		if isCustom and pendingBreakCustomId == vow.Id then
			infoText = tostring(vow.BreakCostText or "Backlash will occur.")
			infoColor = THEME.Bad
		elseif (not isCustom) and pendingBreakPresetId == vow.Id then
			infoText = tostring(vow.BreakCostText or "Backlash will occur.")
			infoColor = THEME.Bad
		else
			infoText = "This vow is active. Breaking it causes backlash."
			infoColor = THEME.Gold
		end
	elseif broken then
		infoText = "Broken for this life."
		infoColor = THEME.Bad
	elseif canMake then
		infoText = pendingMakePresetId == vow.Id and "Click again to sign." or "Permanent unless broken."
		infoColor = pendingMakePresetId == vow.Id and THEME.Gold or THEME.SubText
	else
		infoText = tostring(vow.Reason or "Requirement not met.")
		infoColor = THEME.Muted
	end

	local sideInfo = makeText(card, "SideInfo", infoText, 10, infoColor, true)
	sideInfo.AnchorPoint = Vector2.new(1, 0)
	sideInfo.Size = UDim2.new(0, 138, 0, 104)
	sideInfo.Position = UDim2.new(1, -14, 0, 86)
	sideInfo.TextXAlignment = Enum.TextXAlignment.Center

	actionButton.MouseButton1Click:Connect(function()
		if not buttonActive then
			return
		end

		if isCustom then
			if not owned then
				return
			end

			if pendingBreakCustomId ~= vow.Id then
				pendingBreakCustomId = vow.Id
				pendingBreakPresetId = nil
				pendingMakePresetId = nil
				pendingSignCustom = false
				setStatus(statusLabel, "Breaking a signed vow causes backlash. Confirm to continue.", THEME.Bad)
				rebuild()
				return
			end

			pendingBreakCustomId = nil
			actionButton.Text = "BREAKING..."
			actionButton.Active = false
			bindingVowAction:FireServer("BreakCustomVow", tostring(vow.Id))
			return
		end

		if owned then
			if pendingBreakPresetId ~= vow.Id then
				pendingBreakPresetId = vow.Id
				pendingBreakCustomId = nil
				pendingMakePresetId = nil
				pendingSignCustom = false
				setStatus(statusLabel, "Breaking a vow causes backlash. Confirm to continue.", THEME.Bad)
				rebuild()
				return
			end

			pendingBreakPresetId = nil
			actionButton.Text = "BREAKING..."
			actionButton.Active = false
			bindingVowAction:FireServer("BreakVow", tostring(vow.Id))
			return
		end

		if not canMake or broken then
			return
		end

		if pendingMakePresetId ~= vow.Id then
			pendingMakePresetId = vow.Id
			pendingBreakPresetId = nil
			pendingBreakCustomId = nil
			pendingSignCustom = false
			setStatus(statusLabel, "Click CONFIRM VOW to sign " .. tostring(vow.Name or "this vow") .. ".", THEME.Gold)
			rebuild()
			return
		end

		pendingMakePresetId = nil
		actionButton.Text = "SIGNING..."
		actionButton.Active = false
		bindingVowAction:FireServer("MakeVow", tostring(vow.Id))
	end)
end

local function makeSelectionRow(parent, sectionNumber, title, selectedText, description, onPrev, onNext)
	local row = Instance.new("Frame")
	row.Name = "SelectionRow"
	row.Size = UDim2.new(1, 0, 0, 94)
	row.BackgroundColor3 = THEME.Panel2
	row.BorderSizePixel = 0
	row.ZIndex = nextZ(parent, 1)
	row.Parent = parent
	addCorner(row, 10)
	addStroke(row, THEME.StrokeSoft, 1, 0)

	local header = makeText(row, "Header", "Section " .. tostring(sectionNumber) .. ": " .. title, 12, THEME.Gold, true)
	header.Size = UDim2.new(1, -20, 0, 18)
	header.Position = UDim2.new(0, 12, 0, 9)

	local selector = Instance.new("Frame")
	selector.Name = "Selector"
	selector.Size = UDim2.new(1, -24, 0, 32)
	selector.Position = UDim2.new(0, 12, 0, 33)
	selector.BackgroundColor3 = THEME.Panel3
	selector.BorderSizePixel = 0
	selector.ZIndex = row.ZIndex + 1
	selector.Parent = row
	addCorner(selector, 9)
	addStroke(selector, THEME.StrokeSoft, 1, 0)

	local left = makeButton(selector, "Left", "<", THEME.Button)
	left.Size = UDim2.new(0, 34, 0, 26)
	left.Position = UDim2.new(0, 4, 0.5, -13)

	local value = makeText(selector, "Value", selectedText, 13, THEME.Text, true)
	value.Size = UDim2.new(1, -86, 1, 0)
	value.Position = UDim2.new(0, 43, 0, 0)
	value.TextXAlignment = Enum.TextXAlignment.Center
	value.TextYAlignment = Enum.TextYAlignment.Center
	value.TextTruncate = Enum.TextTruncate.AtEnd

	local right = makeButton(selector, "Right", ">", THEME.Button)
	right.AnchorPoint = Vector2.new(1, 0)
	right.Size = UDim2.new(0, 34, 0, 26)
	right.Position = UDim2.new(1, -4, 0.5, -13)

	local desc = makeText(row, "Description", description or "", 10, THEME.SubText, false)
	desc.Size = UDim2.new(1, -24, 0, 22)
	desc.Position = UDim2.new(0, 12, 0, 69)
	desc.TextYAlignment = Enum.TextYAlignment.Center

	left.MouseButton1Click:Connect(onPrev)
	right.MouseButton1Click:Connect(onNext)

	return row
end

local function makePreviewLine(parent, y, labelText, valueText, valueColor)
	local label = makeText(parent, "Label_" .. labelText, labelText .. ":", 11, THEME.Gold, true)
	label.Size = UDim2.new(0, 122, 0, 18)
	label.Position = UDim2.new(0, 12, 0, y)

	local value = makeText(parent, "Value_" .. labelText, valueText, 11, valueColor or THEME.SubText, false)
	value.Size = UDim2.new(1, -146, 0, 30)
	value.Position = UDim2.new(0, 132, 0, y)

	return value
end

local function makeContractPanel()
	local options = getCustomOptions()
	local sacrifices = options.Sacrifices
	local rewards = options.Rewards
	local severities = options.Severities

	if #sacrifices <= 0 or #rewards <= 0 or #severities <= 0 then
		makeEmptyCard("Custom contracts need the updated GameManager custom vow payload. Your remotes exist, but CustomOptions came back empty.")
		return
	end

	selectedSacrificeIndex = math.clamp(selectedSacrificeIndex, 1, #sacrifices)
	selectedRewardIndex = math.clamp(selectedRewardIndex, 1, #rewards)
	selectedSeverityIndex = math.clamp(selectedSeverityIndex, 1, #severities)

	local sacrifice = getSelected(sacrifices, selectedSacrificeIndex)
	local reward = getSelected(rewards, selectedRewardIndex)
	local severity = getSelected(severities, selectedSeverityIndex)

	if not sacrifice or not reward or not severity then
		makeEmptyCard("Custom contract options loaded incorrectly. Check the CustomOptions payload.")
		return
	end

	local power = getPowerFromSeverity(severity)
	local contractName = tostring(severity.Name or "Minor") .. " Vow of " .. tostring(reward.Name or "Power")
	local statement = "I offer " .. tostring(sacrifice.Name or "Something") .. ". In return, I claim " .. tostring(reward.Name or "Something") .. "."
	local costText = getCostText(sacrifice, power)
	local gainText = getGainText(reward, power)
	local penaltyText = getPenaltyText(sacrifice, reward, power)
	local invalidSameStat = MATCHING_REWARD_BY_SACRIFICE[tostring(sacrifice.Id or "")] == tostring(reward.Id or "")
	local stacked = isSmallScreen() or viewport().X < 720

	local panel = Instance.new("Frame")
	panel.Name = "CustomContractPanel"
	panel.Size = UDim2.new(1, -6, 0, stacked and 820 or 514)
	panel.BackgroundColor3 = Color3.fromRGB(15, 15, 23)
	panel.BorderSizePixel = 0
	panel.ZIndex = content.ZIndex + 1
	panel.Parent = content
	addCorner(panel, 12)
	addStroke(panel, THEME.Purple, 2, 0.08)

	local header = Instance.new("Frame")
	header.Name = "Header"
	header.Size = UDim2.new(1, -24, 0, 56)
	header.Position = UDim2.new(0, 12, 0, 12)
	header.BackgroundColor3 = Color3.fromRGB(22, 19, 34)
	header.BorderSizePixel = 0
	header.ZIndex = panel.ZIndex + 1
	header.Parent = panel
	addCorner(header, 10)
	addStroke(header, THEME.StrokeSoft, 1, 0)

	local title = makeText(header, "Title", "Binding Vow Contract", 18, THEME.Text, true)
	title.Size = UDim2.new(1, -24, 0, 24)
	title.Position = UDim2.new(0, 12, 0, 8)
	title.TextXAlignment = Enum.TextXAlignment.Center
	title.TextYAlignment = Enum.TextYAlignment.Center

	local subtitle = makeText(header, "Subtitle", "Pick a sacrifice, reward, and strictness. Then sign it.", 11, THEME.SubText, false)
	subtitle.Size = UDim2.new(1, -24, 0, 18)
	subtitle.Position = UDim2.new(0, 12, 0, 32)
	subtitle.TextXAlignment = Enum.TextXAlignment.Center

	local form = Instance.new("Frame")
	form.Name = "Form"
	form.Size = stacked and UDim2.new(1, -24, 0, 316) or UDim2.new(0.5, -20, 0, 316)
	form.Position = UDim2.new(0, 12, 0, 80)
	form.BackgroundTransparency = 1
	form.BorderSizePixel = 0
	form.ZIndex = panel.ZIndex + 1
	form.Parent = panel

	local formLayout = Instance.new("UIListLayout")
	formLayout.SortOrder = Enum.SortOrder.LayoutOrder
	formLayout.Padding = UDim.new(0, 10)
	formLayout.Parent = form

	makeSelectionRow(
		form,
		1,
		"What do you sacrifice?",
		tostring(sacrifice.Name or "Unknown"),
		tostring(sacrifice.Line or "Choose what the vow takes from you."),
		function()
			selectedSacrificeIndex = cycleIndex(sacrifices, selectedSacrificeIndex, -1)
			pendingSignCustom = false
			rebuild()
		end,
		function()
			selectedSacrificeIndex = cycleIndex(sacrifices, selectedSacrificeIndex, 1)
			pendingSignCustom = false
			rebuild()
		end
	)

	makeSelectionRow(
		form,
		2,
		"What do you gain?",
		tostring(reward.Name or "Unknown"),
		tostring(reward.Line or "Choose what the vow gives you."),
		function()
			selectedRewardIndex = cycleIndex(rewards, selectedRewardIndex, -1)
			pendingSignCustom = false
			rebuild()
		end,
		function()
			selectedRewardIndex = cycleIndex(rewards, selectedRewardIndex, 1)
			pendingSignCustom = false
			rebuild()
		end
	)

	makeSelectionRow(
		form,
		3,
		"How strict is the vow?",
		tostring(severity.Name or "Unknown"),
		tostring(severity.RequirementText or "No requirement listed."),
		function()
			selectedSeverityIndex = cycleIndex(severities, selectedSeverityIndex, -1)
			pendingSignCustom = false
			rebuild()
		end,
		function()
			selectedSeverityIndex = cycleIndex(severities, selectedSeverityIndex, 1)
			pendingSignCustom = false
			rebuild()
		end
	)

	local preview = Instance.new("Frame")
	preview.Name = "PreviewCard"
	preview.Size = stacked and UDim2.new(1, -24, 0, 316) or UDim2.new(0.5, -20, 0, 316)
	preview.Position = stacked and UDim2.new(0, 12, 0, 410) or UDim2.new(0.5, 8, 0, 80)
	preview.BackgroundColor3 = THEME.Panel2
	preview.BorderSizePixel = 0
	preview.ZIndex = panel.ZIndex + 1
	preview.Parent = panel
	addCorner(preview, 10)
	addStroke(preview, THEME.StrokeSoft, 1, 0)

	local previewTitle = makeText(preview, "PreviewTitle", "PREVIEW CARD", 11, THEME.Gold, true)
	previewTitle.Size = UDim2.new(1, -24, 0, 18)
	previewTitle.Position = UDim2.new(0, 12, 0, 10)
	previewTitle.TextXAlignment = Enum.TextXAlignment.Center

	local previewName = makeText(preview, "PreviewName", contractName, 16, THEME.Purple, true)
	previewName.Size = UDim2.new(1, -24, 0, 24)
	previewName.Position = UDim2.new(0, 12, 0, 35)
	previewName.TextXAlignment = Enum.TextXAlignment.Center
	previewName.TextYAlignment = Enum.TextYAlignment.Center

	local statementBox = Instance.new("Frame")
	statementBox.Name = "StatementBox"
	statementBox.Size = UDim2.new(1, -24, 0, 58)
	statementBox.Position = UDim2.new(0, 12, 0, 68)
	statementBox.BackgroundColor3 = THEME.Panel3
	statementBox.BorderSizePixel = 0
	statementBox.ZIndex = preview.ZIndex + 1
	statementBox.Parent = preview
	addCorner(statementBox, 9)
	addStroke(statementBox, THEME.StrokeSoft, 1, 0)

	local statementLabel = makeText(
		statementBox,
		"Statement",
		invalidSameStat and "This contract cancels itself out. Choose a different reward or sacrifice." or statement,
		12,
		invalidSameStat and THEME.Bad or THEME.Text,
		false
	)
	statementLabel.Size = UDim2.new(1, -20, 1, -10)
	statementLabel.Position = UDim2.new(0, 10, 0, 5)
	statementLabel.TextXAlignment = Enum.TextXAlignment.Center
	statementLabel.TextYAlignment = Enum.TextYAlignment.Center

	makePreviewLine(preview, 140, "Name", contractName, THEME.Text)
	makePreviewLine(preview, 174, "Cost", costText, THEME.Bad)
	makePreviewLine(preview, 208, "Gain", gainText, THEME.Green)
	makePreviewLine(
		preview,
		242,
		"Requirement",
		invalidSameStat and "Sacrifice and reward cannot be the same stat." or tostring(severity.RequirementText or "No requirement."),
		invalidSameStat and THEME.Bad or THEME.SubText
	)

	local penalty = makeText(preview, "Penalty", "Penalty if broken: " .. penaltyText, 10, THEME.Bad, true)
	penalty.Size = UDim2.new(1, -24, 0, 40)
	penalty.Position = UDim2.new(0, 12, 0, 274)

	local footer = Instance.new("Frame")
	footer.Name = "Footer"
	footer.Size = UDim2.new(1, -24, 0, 74)
	footer.Position = UDim2.new(0, 12, 1, -86)
	footer.BackgroundColor3 = Color3.fromRGB(18, 17, 27)
	footer.BorderSizePixel = 0
	footer.ZIndex = panel.ZIndex + 1
	footer.Parent = panel
	addCorner(footer, 10)
	addStroke(footer, THEME.StrokeSoft, 1, 0)

	local note = makeText(
		footer,
		"Note",
		invalidSameStat and "Choose different stats. A vow cannot sacrifice and reward the same thing." or (pendingSignCustom and "Confirm signature to lock this vow into your life." or "Custom vows are self-imposed. Useful, but never free."),
		11,
		invalidSameStat and THEME.Bad or (pendingSignCustom and THEME.Gold or THEME.SubText),
		true
	)

	note.Size = stacked and UDim2.new(1, -24, 0, 28) or UDim2.new(1, -380, 1, -20)
	note.Position = UDim2.new(0, 14, 0, 10)
	note.TextYAlignment = Enum.TextYAlignment.Center

	local cancelButton = makeButton(footer, "Cancel", "CANCEL", THEME.Button)
	cancelButton.AnchorPoint = Vector2.new(1, 0.5)
	cancelButton.Size = stacked and UDim2.new(0.42, -10, 0, 34) or UDim2.new(0, 128, 0, 38)
	cancelButton.Position = stacked and UDim2.new(0.42, 4, 0.72, 0) or UDim2.new(1, -242, 0.5, 0)

	local signButton = makeButton(footer, "Sign", invalidSameStat and "INVALID CONTRACT" or (pendingSignCustom and "CONFIRM SIGNATURE" or "SIGN CONTRACT"), invalidSameStat and THEME.ButtonDisabled or (pendingSignCustom and THEME.RedDark or THEME.Purple))
	signButton.AnchorPoint = Vector2.new(1, 0.5)
	signButton.Size = stacked and UDim2.new(0.58, -18, 0, 34) or UDim2.new(0, 218, 0, 38)
	signButton.Position = stacked and UDim2.new(1, -14, 0.72, 0) or UDim2.new(1, -14, 0.5, 0)
	signButton.Active = not invalidSameStat

	cancelButton.MouseButton1Click:Connect(function()
		pendingSignCustom = false
		setStatus(statusLabel, "Contract draft cleared.", THEME.Muted)
		rebuild()
	end)

	signButton.MouseButton1Click:Connect(function()
		if invalidSameStat then
			setStatus(statusLabel, "Choose different stats for sacrifice and reward.", THEME.Bad)
			return
		end

		if not pendingSignCustom then
			pendingSignCustom = true
			pendingMakePresetId = nil
			pendingBreakPresetId = nil
			pendingBreakCustomId = nil
			setStatus(statusLabel, "Confirm your signature to bind the custom vow.", THEME.Gold)
			rebuild()
			return
		end

		pendingSignCustom = false
		signButton.Text = "SIGNING..."
		signButton.Active = false

		bindingVowAction:FireServer("MakeCustomVow", {
			SacrificeId = tostring(sacrifice.Id),
			RewardId = tostring(reward.Id),
			SeverityId = tostring(severity.Id),
		})
	end)
end

local function makeCustomVowList()
	local customVows = typeof(currentPayload) == "table" and currentPayload.CustomVows or nil

	makeSectionTitle("SIGNED CUSTOM CONTRACTS")

	if typeof(customVows) ~= "table" or #customVows <= 0 then
		makeEmptyCard("No custom vows signed yet. Draft a contract above to create one.")
		return
	end

	for index, vow in ipairs(customVows) do
		makeVowCard(vow, index, true)
	end
end

local function makePresetList()
	local vows = typeof(currentPayload) == "table" and currentPayload.Vows or nil

	makeSectionTitle("PRESET BINDING VOWS")

	if typeof(vows) ~= "table" or #vows <= 0 then
		makeEmptyCard("No preset Binding Vows are available yet.")
		return
	end

	for index, vow in ipairs(vows) do
		makeVowCard(vow, index, false)
	end
end

rebuild = function()
	clearGuiObjects(content)
	installContentLayout()

	updateTabs()
	infoBody.Text = getStatLine()

	if currentTab == "Custom" then
		makeContractPanel()
		makeCustomVowList()
	else
		makePresetList()
	end

	updateCanvas()
end

local function openMenu()
	if isOpen then
		return
	end

	isOpen = true
	pendingMakePresetId = nil
	pendingBreakPresetId = nil
	pendingBreakCustomId = nil
	pendingSignCustom = false

	layout()
	currentPayload = fetchPayload()
	rebuild()

	overlay.Visible = true
	window.Visible = true
	overlay.BackgroundTransparency = 1
	window.BackgroundTransparency = 1
	window.Position = UDim2.new(0.5, 0, 0.52, 0)

	tween(overlay, 0.18, {
		BackgroundTransparency = 0.38,
	})

	tween(window, 0.2, {
		BackgroundTransparency = 0,
		Position = UDim2.new(0.5, 0, 0.5, 0),
	})
end

local function closeMenu()
	if not isOpen then
		return
	end

	isOpen = false
	pendingMakePresetId = nil
	pendingBreakPresetId = nil
	pendingBreakCustomId = nil
	pendingSignCustom = false

	tween(overlay, 0.16, {
		BackgroundTransparency = 1,
	})

	tween(window, 0.16, {
		BackgroundTransparency = 1,
	})

	task.delay(0.18, function()
		if not isOpen then
			overlay.Visible = false
			window.Visible = false
		end
	end)
end

openButton.MouseButton1Click:Connect(function()
	if isOpen then
		closeMenu()
	else
		openMenu()
	end
end)

closeButton.MouseButton1Click:Connect(closeMenu)

customTab.MouseButton1Click:Connect(function()
	currentTab = "Custom"
	pendingMakePresetId = nil
	pendingBreakPresetId = nil
	pendingBreakCustomId = nil
	pendingSignCustom = false
	rebuild()
end)

presetTab.MouseButton1Click:Connect(function()
	currentTab = "Preset"
	pendingMakePresetId = nil
	pendingBreakPresetId = nil
	pendingBreakCustomId = nil
	pendingSignCustom = false
	rebuild()
end)

overlay.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
		return
	end

	local mousePosition = UserInputService:GetMouseLocation()
	local pos = window.AbsolutePosition
	local size = window.AbsoluteSize

	local inside =
		mousePosition.X >= pos.X and
		mousePosition.X <= pos.X + size.X and
		mousePosition.Y >= pos.Y and
		mousePosition.Y <= pos.Y + size.Y

	if not inside then
		closeMenu()
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end

	if input.KeyCode == Enum.KeyCode.Escape and isOpen then
		closeMenu()
	end
end)

bindingVowAction.OnClientEvent:Connect(function(result)
	if typeof(result) ~= "table" then
		setStatus(statusLabel, "Binding vow response was invalid.", THEME.Bad)
		return
	end

	pendingMakePresetId = nil
	pendingBreakPresetId = nil
	pendingBreakCustomId = nil
	pendingSignCustom = false

	if typeof(result.Data) == "table" then
		currentPayload = result.Data
	else
		currentPayload = fetchPayload()
	end

	refreshOpenBadge()

	if result.Success == true then
		setStatus(statusLabel, tostring(result.Message or "Binding Vow updated."), THEME.Green)
	else
		setStatus(statusLabel, tostring(result.Message or "Could not update Binding Vow."), THEME.Bad)
	end

	if isOpen then
		rebuild()
	end
end)

updateLifeEvent.OnClientEvent:Connect(function(stats)
	currentStats = stats

	if typeof(stats) ~= "table" then
		return
	end

	if isOpen then
		infoBody.Text = getStatLine()
	end
end)

if workspace.CurrentCamera then
	workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(layout)
end

workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
	task.wait()

	if workspace.CurrentCamera then
		workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(layout)
	end

	layout()
end)

layout()

if game:GetService("RunService"):IsStudio() then print("[BitKaisenBindingVowsUI] Loaded readable dark Binding Vows UI.") end

