	header.Name = "SectionHeader"
	header.Size = UDim2.new(1, -8, 0, 26)
	header.BackgroundTransparency = 1
	header.TextColor3 = COLORS.SubText
	header.TextSize = 13
	header.Font = Enum.Font.GothamBlack
	header.TextXAlignment = Enum.TextXAlignment.Left
	header.Text = string.upper(text)
	header.LayoutOrder = order or 0
	header.ZIndex = 303
	header.Parent = scroll
	return header
end

local function getRelationshipPageSize()
	return isMobileViewport() and 3 or 5
end

local function makePageControls(label, totalCount, currentPage, pageSize, order, setPage)
	local totalPages = math.max(1, math.ceil(totalCount / pageSize))
	local controls = Instance.new("Frame")
	controls.Name = label .. "PageControls"
	controls.Size = UDim2.new(1, -8, 0, 38)
	controls.BackgroundColor3 = Color3.fromRGB(16, 16, 24)
	controls.BorderSizePixel = 0
	controls.LayoutOrder = order or 0
	controls.ZIndex = 303
	controls.Parent = scroll
	addCorner(controls, 8)
	addStroke(controls, Color3.fromRGB(40, 40, 56), 1)

	local info = Instance.new("TextLabel")
	info.Size = UDim2.new(1, -176, 1, 0)
	info.Position = UDim2.new(0, 12, 0, 0)
	info.BackgroundTransparency = 1
	info.TextColor3 = COLORS.SubText
	info.TextSize = isMobileViewport() and 10 or 12
	info.Font = Enum.Font.GothamBold
	info.TextXAlignment = Enum.TextXAlignment.Left
	info.Text = string.format("Page %d/%d | %d total", currentPage, totalPages, totalCount)
	info.ZIndex = 304
	info.Parent = controls

	local function makeNav(text, x, enabled, delta)
		local button = Instance.new("TextButton")
		button.Size = UDim2.new(0, 74, 0, 26)
		button.Position = UDim2.new(1, x, 0.5, -13)
		button.BackgroundColor3 = enabled and COLORS.Button or Color3.fromRGB(24, 24, 32)
		button.BorderSizePixel = 0
		button.TextColor3 = enabled and COLORS.Text or COLORS.Muted
		button.TextSize = 11
		button.Font = Enum.Font.GothamBlack
		button.Text = text
		button.AutoButtonColor = enabled
		button.Active = enabled
		button.ZIndex = 304
		button.Parent = controls
		addCorner(button, 7)
		addStroke(button, Color3.fromRGB(50, 50, 68), 1)
		if enabled then
			button.MouseButton1Click:Connect(function()
				setPage(math.clamp(currentPage + delta, 1, totalPages))
				refreshRelationships(false)
			end)
		end
	end

	makeNav("PREV", -158, currentPage > 1, -1)
	makeNav("NEXT", -80, currentPage < totalPages, 1)
	return controls
end

local function makeBar(parent, labelText, value, color, y)
	local clamped = clampPercent(value)
	local mobile = isMobileViewport()
	local small = isSmallMobileViewport()
	local labelW = mobile and 48 or 74
	local barX = mobile and 70 or 108
	local percentW = mobile and 32 or 44
	local rightPad = mobile and 44 or 72

	local label = Instance.new("TextLabel")
	label.Name = labelText .. "Label"
	label.Size = UDim2.new(0, labelW, 0, 18)
	label.Position = UDim2.new(0, mobile and 12 or 18, 0, y)
	label.BackgroundTransparency = 1
	label.TextColor3 = color
	label.TextSize = small and 9 or (mobile and 10 or 12)
	label.Font = Enum.Font.GothamBlack
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = labelText
	label.ZIndex = 305
	label.Parent = parent

	local back = Instance.new("Frame")
	back.Name = labelText .. "Back"
	back.Size = UDim2.new(1, -(barX + rightPad), 0, mobile and 7 or 8)
	back.Position = UDim2.new(0, barX, 0, y + 5)
	back.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	back.BorderSizePixel = 0
	back.ZIndex = 305
	back.Parent = parent
	addCorner(back, 999)

	local fill = Instance.new("Frame")
	fill.Name = labelText .. "Fill"
	fill.Size = UDim2.new(clamped / 100, 0, 1, 0)
	fill.BackgroundColor3 = color
	fill.BorderSizePixel = 0
	fill.ZIndex = 306
	fill.Parent = back
	addCorner(fill, 999)

	local percent = Instance.new("TextLabel")
