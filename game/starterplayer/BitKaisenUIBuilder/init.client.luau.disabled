local function createNavButton(name)
	local button = Instance.new("TextButton")
	button.Name = name .. "Button"
	button.Size = UDim2.new(0.86, 0, 0, 42)
	button.BackgroundColor3 = THEME.Panel2
	button.TextColor3 = THEME.SubText
	button.TextSize = 14
	button.Font = Enum.Font.GothamBlack
	button.Text = name
	button.AutoButtonColor = false
	button.BorderSizePixel = 0
	button.Parent = navPanel
	addCorner(button, 9)
	addStroke(button, THEME.Stroke, 1)

	local accent = Instance.new("Frame")
	accent.Name = "Accent"
	accent.Size = UDim2.new(0, 4, 1, -14)
	accent.Position = UDim2.new(0, 8, 0, 7)
	accent.BackgroundColor3 = THEME.Red
	accent.BorderSizePixel = 0
	accent.Parent = button
	addCorner(accent, 999)

	return button
end

local missionsBtn = createNavButton("MISSIONS")
local activitiesBtn = createNavButton("ACTIVITIES")
local relateBtn = createNavButton("RELATIONSHIPS")
local assetsBtn = createNavButton("ASSETS")

local function removeSettingsNavButton()
	for _, child in ipairs(navPanel:GetChildren()) do
		if child:IsA("TextButton") then
			local childName = string.upper(tostring(child.Name or ""))
			local childText = string.upper(tostring(child.Text or ""))
			if childName == "SETTINGSBUTTON" or childText == "SETTINGS" then
				child:Destroy()
			end
		end
	end
end

