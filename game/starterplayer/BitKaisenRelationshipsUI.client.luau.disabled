-- LocalScript: BitKaisenRelationshipsUI
-- Location: StarterPlayerScripts
-- Purpose:
-- Stable Relationships UI that does not close, flicker, or reset scroll after actions.
-- Keeps relationship bars, romance rules, action buttons, and the profile/info card.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local getRelationships = ReplicatedStorage:WaitForChild("GetRelationships")
local relationshipAction = ReplicatedStorage:WaitForChild("RelationshipAction")
local RelationshipCache = require(script.Parent:WaitForChild("BitKaisenRelationshipCache"))

local bitKaisenGui = playerGui:WaitForChild("BitKaisenGui")
local mainPanel = bitKaisenGui:WaitForChild("MainPanel")
local navPanel = mainPanel:WaitForChild("NavPanel")

local oldRelationshipButton = navPanel:WaitForChild("RELATIONSHIPSButton")
local relationshipButton = oldRelationshipButton:Clone()
relationshipButton.Name = "RELATIONSHIPSButton"
relationshipButton.Parent = navPanel
relationshipButton.LayoutOrder = oldRelationshipButton.LayoutOrder
oldRelationshipButton:Destroy()

local missionsButton = navPanel:FindFirstChild("MISSIONSButton")
local activitiesButton = navPanel:FindFirstChild("ACTIVITIESButton")
local assetsButton = navPanel:FindFirstChild("ASSETSButton")

local existingOverlay = bitKaisenGui:FindFirstChild("RelationshipsOverlay")
if existingOverlay then
	existingOverlay:Destroy()
end

