local settingsWindow, closeSettingsBtn, settingsScroll = createWindow("SettingsWindow", "MENU")
settingsWindow.Size = UDim2.new(0, 510, 0, 520)

local function isMobileViewport()
	local camera = workspace.CurrentCamera
	local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
	return viewport.X < 900 or viewport.Y > viewport.X
end

local function applyResponsiveLayout()
	local camera = workspace.CurrentCamera
	local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
	local isMobile      = viewport.X < 900 or viewport.Y > viewport.X
	local isSmallMobile = viewport.X < 520
	local isPortraitMobile = isMobile and viewport.Y > viewport.X

	local function setProfileTextSize(sizeTable)
		nameLabel.TextSize   = sizeTable.Name
		ageLabel.TextSize    = sizeTable.Age
		gradeLabel.TextSize  = sizeTable.Small
		clanLabel.TextSize   = sizeTable.Small
		techLabel.TextSize   = sizeTable.Small
		traitLabel.TextSize  = math.max(10, sizeTable.Small - 1)
		ceLabel.TextSize     = sizeTable.Small
		moneyLabel.TextSize  = sizeTable.Small
		repLabel.TextSize    = sizeTable.Small
		recLabel.TextSize    = sizeTable.Small
		schoolLabel.TextSize = sizeTable.Small
		pathLabel.TextSize   = math.max(10, sizeTable.Small - 1)
		alignmentLabel.TextSize = math.max(10, sizeTable.Small - 1)
		progressLabel.TextSize = math.max(9, sizeTable.Small - 2)
	end

	if isMobile then
		rootScale.Scale = 1
		profileCard.ClipsDescendants  = true
		profileScroll.ScrollingEnabled = true
		profileScroll.ScrollBarThickness = isSmallMobile and 3 or 4
		logContainer.ClipsDescendants = true
		actionRow.ClipsDescendants    = true
		navPanel.ClipsDescendants     = true

		if isPortraitMobile then
			-- More vertical room for profile stats on phones.
			profileCard.Size     = UDim2.new(0.94, 0, 0.40, 0)
			profileCard.Position = UDim2.new(0.03, 0, 0.065, 0)
			logContainer.Size     = UDim2.new(0.94, 0, 0.28, 0)
			logContainer.Position = UDim2.new(0.03, 0, 0.485, 0)
			actionRow.Size     = UDim2.new(0.94, 0, 0.06, 0)
			actionRow.Position = UDim2.new(0.03, 0, 0.785, 0)
			navPanel.Size     = UDim2.new(0.94, 0, 0.095, 0)
			navPanel.Position = UDim2.new(0.03, 0, 0.858, 0)
		else
			-- Landscape mobile still needs enough height for school/path/alignment.
			profileCard.Size     = UDim2.new(0.94, 0, 0.43, 0)
			profileCard.Position = UDim2.new(0.03, 0, 0.08, 0)
			logContainer.Size     = UDim2.new(0.94, 0, 0.235, 0)
			logContainer.Position = UDim2.new(0.03, 0, 0.525, 0)
			actionRow.Size     = UDim2.new(0.94, 0, 0.065, 0)
			actionRow.Position = UDim2.new(0.03, 0, 0.765, 0)
			navPanel.Size     = UDim2.new(0.94, 0, 0.105, 0)
			navPanel.Position = UDim2.new(0.03, 0, 0.842, 0)
		end

		setProfileTextSize({
			Name  = isSmallMobile and 16 or 19,
			Age   = isSmallMobile and 11 or 13,
			Small = isSmallMobile and 9 or 11,
		})

		logText.TextSize       = isSmallMobile and 13 or 15
		ageUpButton.TextSize   = isSmallMobile and 17 or 20

		profileLayout.Padding      = UDim.new(0, isSmallMobile and 3 or 4)
		profilePadding.PaddingTop    = UDim.new(0, isSmallMobile and 8  or 10)
		profilePadding.PaddingBottom = UDim.new(0, isSmallMobile and 8  or 10)
		profilePadding.PaddingLeft   = UDim.new(0, isSmallMobile and 12 or 16)
		profilePadding.PaddingRight  = UDim.new(0, isSmallMobile and 12 or 16)

		logPadding.PaddingTop    = UDim.new(0, 14)
		logPadding.PaddingBottom = UDim.new(0, 14)
		logPadding.PaddingLeft   = UDim.new(0, 18)
		logPadding.PaddingRight  = UDim.new(0, 18)

		navLayout.FillDirection    = Enum.FillDirection.Horizontal
		navLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
		navLayout.VerticalAlignment   = Enum.VerticalAlignment.Center
		local navButtons = {}
		for _, child in ipairs(navPanel:GetChildren()) do
			if child:IsA("TextButton") then
				table.insert(navButtons, child)
			end
		end

		local navOrder = {
			MISSIONSButton = 1,
			ACTIVITIESButton = 2,
			JOBSButton = 3,
			ASSETSButton = 4,
			RELATIONSHIPSButton = 5,
			HISTORYButton = 6,
			TITLESButton = 7,
			DOMAINButton = 8,
			AFFILIATIONSButton = 9,
			DEVTOOLSButton = 99,
		}
		table.sort(navButtons, function(a, b)
			local aOrder = navOrder[a.Name] or tonumber(a.LayoutOrder) or 90
			local bOrder = navOrder[b.Name] or tonumber(b.LayoutOrder) or 90
			return aOrder < bOrder
		end)

		local navGap = isSmallMobile and 6 or 8
		local navCount = math.max(#navButtons, 1)
		navLayout.Padding = UDim.new(0, navGap)
		navPanel.ScrollingEnabled = true
		navPanel.ScrollingDirection = Enum.ScrollingDirection.X
		navPanel.AutomaticCanvasSize = Enum.AutomaticSize.X
		navPanel.CanvasSize = UDim2.new(0, 0, 0, 0)
		navPanel.CanvasPosition = Vector2.new(0, 0)
		navPanel.ScrollBarThickness = 3
		local fixedNavWidth = isSmallMobile and 92 or 108
		local navButtonWidth = 0
		for _, child in ipairs(navButtons) do
			child.LayoutOrder = navOrder[child.Name] or child.LayoutOrder
			child.BackgroundColor3 = THEME.Panel2
			child.TextColor3 = THEME.SubText
			child.AutoButtonColor = false
			child.Size = UDim2.new(0, fixedNavWidth, 0, isSmallMobile and 34 or 40)
			child.TextSize = isSmallMobile and 7 or 8
			child.TextWrapped = false
			child.TextTruncate = Enum.TextTruncate.AtEnd
			local accent = child:FindFirstChild("Accent")
			if accent then
				accent.Size     = UDim2.new(0, 4, 1, -14)
				accent.Position = UDim2.new(0, 6, 0, 7)
			end
		end
		task.defer(function()
			if navPanel and navPanel.Parent then
				navPanel.CanvasPosition = Vector2.new(0, 0)
			end
		end)

		settingsButton.Size     = UDim2.new(0, isSmallMobile and 38 or 44, 0, isSmallMobile and 38 or 44)
		settingsButton.Position = UDim2.new(1, -18, 0, isPortraitMobile and 18 or 20)
		settingsButton.ZIndex   = 25

		settingsWindow.Size  = UDim2.new(0.90, 0, 0.72, 0)
		missionWindow.Size   = UDim2.new(0.90, 0, 0.72, 0)
		activityWindow.Size  = UDim2.new(0.90, 0, 0.72, 0)

	else
		rootScale.Scale = 1
		-- Phase 1 profile fix: the new society/path/progress lines can overflow
		-- the right-side profile card on desktop, so keep this panel scrollable too.
		profileCard.ClipsDescendants  = true
		profileScroll.ScrollingEnabled = true
		profileScroll.ScrollBarThickness = 4
		logContainer.ClipsDescendants = false
		actionRow.ClipsDescendants    = false
		navPanel.ClipsDescendants     = false

		logContainer.Size     = UDim2.new(0.61, 0, 0.76, 0)
		logContainer.Position = UDim2.new(0.025, 0, 0.07, 0)
		actionRow.Size     = UDim2.new(0.61, 0, 0.08, 0)
		actionRow.Position = UDim2.new(0.025, 0, 0.86, 0)
		profileCard.Size     = UDim2.new(0.30, 0, 0.60, 0)
		profileCard.Position = UDim2.new(0.67, 0, 0.07, 0)
		navPanel.Size     = UDim2.new(0.30, 0, 0.28, 0)
		navPanel.Position = UDim2.new(0.67, 0, 0.68, 0)

		setProfileTextSize({ Name = 24, Age = 16, Small = 14 })
		logText.TextSize     = 17
		ageUpButton.TextSize = 22

		profileLayout.Padding      = UDim.new(0, 6)
		profilePadding.PaddingTop    = UDim.new(0, 15)
		profilePadding.PaddingBottom = UDim.new(0, 15)
		profilePadding.PaddingLeft   = UDim.new(0, 20)
		profilePadding.PaddingRight  = UDim.new(0, 20)

		logPadding.PaddingTop    = UDim.new(0, 20)
		logPadding.PaddingBottom = UDim.new(0, 20)
		logPadding.PaddingLeft   = UDim.new(0, 25)
		logPadding.PaddingRight  = UDim.new(0, 25)

		navPanel.ClipsDescendants = true
		navPanel.ScrollingEnabled = true
		navPanel.ScrollingDirection = Enum.ScrollingDirection.Y
		navPanel.AutomaticCanvasSize = Enum.AutomaticSize.Y
		navPanel.CanvasSize = UDim2.new(0, 0, 0, 0)
		navPanel.CanvasPosition = Vector2.new(0, 0)
		navPanel.ScrollBarThickness = 4
		navLayout.FillDirection    = Enum.FillDirection.Vertical
		navLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
		navLayout.VerticalAlignment   = Enum.VerticalAlignment.Top

		local btnCount = 0
		for _, child in ipairs(navPanel:GetChildren()) do
			if child:IsA("TextButton") then btnCount += 1 end
		end
		btnCount = math.max(btnCount, 1)

		local gap = 8
		navLayout.Padding = UDim.new(0, gap)
		local btnH        = 38
		local btnTextSize = 13

		for _, child in ipairs(navPanel:GetChildren()) do
			if child:IsA("TextButton") then
				child.BackgroundColor3 = THEME.Panel2
				child.TextColor3 = THEME.SubText
				child.AutoButtonColor = false
				child.Size     = UDim2.new(0.86, 0, 0, btnH)
				child.TextSize = btnTextSize
				local accent = child:FindFirstChild("Accent")
				if accent then
					accent.Size     = UDim2.new(0, 4, 1, -14)
					accent.Position = UDim2.new(0, 8, 0, 7)
				end
			end
		end

		settingsButton.Size     = UDim2.new(0, 42, 0, 42)
		settingsButton.Position = UDim2.new(1, -18, 0, 16)
		settingsButton.ZIndex   = 5

		settingsWindow.Size = UDim2.new(0, 510, 0, 520)
		missionWindow.Size  = UDim2.new(0.56, 0, 0.76, 0)
		activityWindow.Size = UDim2.new(0.56, 0, 0.76, 0)
	end
end

applyResponsiveLayout()
task.defer(applyResponsiveLayout)
task.delay(0.25, applyResponsiveLayout)

navPanel.ChildAdded:Connect(function(child)
	if child:IsA("TextButton") then
		task.defer(applyResponsiveLayout)
	end
end)

if workspace.CurrentCamera then
	workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsiveLayout)
end

workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
	task.wait()
	applyResponsiveLayout()
	if workspace.CurrentCamera then
		workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsiveLayout)
	end
end)

local function lockMobileMenuButton()
	if not settingsButton then
		return
	end

	if isMobileViewport() then
		local camera = workspace.CurrentCamera
		local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
		local isSmallMobile = viewport.X < 520
		settingsButton.AnchorPoint = Vector2.new(1, 0)
		settingsButton.Size = UDim2.new(0, isSmallMobile and 38 or 44, 0, isSmallMobile and 38 or 44)
		settingsButton.Position = UDim2.new(1, -18, 0, 18)
		local scaleObject = settingsButton:FindFirstChildOfClass("UIScale")
		if scaleObject then
			scaleObject.Scale = 1
		end
	end
end

RunService.RenderStepped:Connect(lockMobileMenuButton)

