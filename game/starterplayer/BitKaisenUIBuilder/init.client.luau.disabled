rebuildProductsShop = function()
	clearSettingsCards()
	createSettingsSectionHeader("Products / Shop")
	for categoryName, products in pairs(SHOP_PRODUCTS) do
		createSettingsSectionHeader(categoryName)
		local accent = getShopAccent(categoryName)
		for _, item in ipairs(products) do
			if item.TestOnly ~= true or game.PlaceId == 104206065947170 then
				createProductCard(item, accent)
			end
		end
	end
	createMenuButtonCard("Back to Menu", "Return to the main menu hub.", THEME.Red, "BACK", function()
		rebuildSettingsWindow()
	end)
end

rebuildSaveSlotsWindow = function()
	clearSettingsCards()
	createSettingsSectionHeader("Save Slots")

	local payload = nil
	local ok, result = pcall(function() return getSaveSlots:InvokeServer() end)

	if ok and typeof(result) == "table" then
		payload = result
	else
		createMenuNotice("Could not load save slots right now. Check the server output for GetSaveSlots errors.")
		createMenuButtonCard("Back to Menu", "Return to the main menu hub.", THEME.Red, "BACK", function()
			rebuildSettingsWindow()
		end)
		return
	end

	local hasVIP = payload.HasVIP == true
	local vipId = tonumber(payload.VIPGamePassId) or VIP_SORCERER_PASS_ID
	local slotCount = tonumber(payload.SlotCount) or 3
	local selectedSlot = tonumber(payload.SelectedSlot) or 1

	if vipId > 0 then VIP_SORCERER_PASS_ID = vipId end

	if hasVIP then
		createMenuNotice("VIP active. Slots 1-3 are unlocked. Loading or creating a slot resets the life log so old dialogue does not bleed into the new life.")
	else
		createMenuNotice("Free players can use Slot 1. VIP Sorcerer Pass unlocks Slots 2 and 3.")
	end

	for slotId = 1, slotCount do
		local slot = payload.Slots and payload.Slots[slotId]
		local exists = slot and slot.Exists == true
		local locked = slot and slot.Locked == true
		local isSelected = selectedSlot == slotId
		local accent = locked and THEME.Gold or (isSelected and THEME.Blue or THEME.Red)
		local card = createSettingsCard(128)

		local stripe = Instance.new("Frame")
		stripe.Size = UDim2.new(0, 4, 1, -24)
		stripe.Position = UDim2.new(0, 12, 0, 12)
		stripe.BackgroundColor3 = accent
		stripe.BorderSizePixel = 0
		stripe.ZIndex = 54
		stripe.Parent = card
		addCorner(stripe, 999)

		local title = Instance.new("TextLabel")
		title.Size = UDim2.new(1, -165, 0, 24)
		title.Position = UDim2.new(0, 28, 0, 12)
		title.BackgroundTransparency = 1
		title.TextColor3 = THEME.Text
		title.TextSize = 16
		title.Font = Enum.Font.GothamBlack
		title.TextXAlignment = Enum.TextXAlignment.Left
		title.Text = "Slot " .. tostring(slotId) .. (isSelected and "  [ACTIVE]" or "")
		title.ZIndex = 54
		title.Parent = card

		local statusText = "Empty Slot"
		if locked then
			statusText = "VIP LOCKED"
		elseif exists then
			statusText = tostring(slot.Name or "Unknown") .. " | Age " .. tostring(slot.Age or 0) .. " | " .. tostring(slot.Grade or "Unknown")
		end

		local status = Instance.new("TextLabel")
		status.Size = UDim2.new(1, -165, 0, 22)
		status.Position = UDim2.new(0, 28, 0, 39)
		status.BackgroundTransparency = 1
		status.TextColor3 = locked and THEME.Gold or THEME.SubText
		status.TextSize = 13
		status.Font = Enum.Font.GothamBold
		status.TextXAlignment = Enum.TextXAlignment.Left
		status.Text = statusText
		status.ZIndex = 54
		status.Parent = card

		local detailText = "Create a fresh life in this slot."
		if locked then
			detailText = "Buy VIP Sorcerer Pass to unlock this save slot."
		elseif exists then
			detailText = "Technique: " .. tostring(slot.CursedTechnique or "None") .. " | Generation " .. tostring(slot.Generation or 1) .. " | " .. ((slot.Alive ~= false) and "Alive" or "Dead")
		end

		local details = Instance.new("TextLabel")
		details.Size = UDim2.new(1, -165, 0, 44)
		details.Position = UDim2.new(0, 28, 0, 64)
		details.BackgroundTransparency = 1
		details.TextColor3 = THEME.Muted
		details.TextSize = 12
		details.Font = Enum.Font.GothamMedium
		details.TextWrapped = true
		details.TextXAlignment = Enum.TextXAlignment.Left
		details.TextYAlignment = Enum.TextYAlignment.Top
		details.Text = detailText
		details.ZIndex = 54
		details.Parent = card

		local mainButton = Instance.new("TextButton")
		mainButton.Size = UDim2.new(0, 112, 0, 36)
		mainButton.Position = UDim2.new(1, -128, 0, 22)
		mainButton.BackgroundColor3 = locked and THEME.Panel3 or THEME.RedDark
		mainButton.BorderSizePixel = 0
		mainButton.TextColor3 = THEME.Text
		mainButton.TextSize = 12
		mainButton.Font = Enum.Font.GothamBlack
		mainButton.Text = locked and "GET VIP" or (exists and "LOAD" or "CREATE")
		mainButton.AutoButtonColor = false
		mainButton.ZIndex = 55
		mainButton.Parent = card
		addCorner(mainButton, 8)
		addStroke(mainButton, accent, 1)

		mainButton.MouseButton1Click:Connect(function()
			if locked then promptVIPPurchase() return end
			if exists then
				selectSaveSlot:FireServer(slotId)
			else
				createSaveSlot:FireServer(slotId)
			end
			task.delay(0.35, function()
				if settingsWindow.Visible then rebuildSaveSlotsWindow() end
			end)
		end)

		if exists and not locked then
			local deleteButton = Instance.new("TextButton")
			deleteButton.Size = UDim2.new(0, 112, 0, 32)
			deleteButton.Position = UDim2.new(1, -128, 0, 66)
			deleteButton.BackgroundColor3 = THEME.Panel3
			deleteButton.BorderSizePixel = 0
			deleteButton.TextColor3 = THEME.Bad
			deleteButton.TextSize = 11
			deleteButton.Font = Enum.Font.GothamBlack
			deleteButton.Text = "DELETE"
			deleteButton.AutoButtonColor = false
			deleteButton.ZIndex = 55
			deleteButton.Parent = card
			addCorner(deleteButton, 8)
			addStroke(deleteButton, THEME.Bad, 1)

			deleteButton.MouseButton1Click:Connect(function()
				deleteSaveSlot:FireServer(slotId)
				task.delay(0.35, function()
					if settingsWindow.Visible then rebuildSaveSlotsWindow() end
				end)
			end)
		end
	end

	createMenuButtonCard("Back to Menu", "Return to the main menu hub.", THEME.Red, "BACK", function()
		rebuildSettingsWindow()
	end)
end

local function rebuildSettingsControls()
	clearSettingsCards()
	createSettingsSectionHeader("Game Settings")
	createSettingsToggle("Fast Text", "Use shorter / snappier UI text pacing when supported.", "FastText")
	createSettingsToggle("High Contrast Text", "Boost readability a bit for log and menu text.", "HighContrastText")
	createSettingsSectionHeader("Audio")
	createSettingsStepper("Music Volume", "Adjust background music volume for the experience.", "MusicVolume")
	createSettingsStepper("SFX Volume", "Adjust button and event sound effect volume.", "SFXVolume")
	createMenuButtonCard("Back to Menu", "Return to the main menu hub.", THEME.Red, "BACK", function()
		rebuildSettingsWindow()
	end)
end

local codeLikeConfirmed = false

local DEFAULT_ACTIVE_CODES = {
	{ Index = 1, Code = "ALPHA35", Name = "ALPHA35", RewardText = "+$5,000, +10 CE, and +3 Reputation." },
	{ Index = 2, Code = "MOBILEFIX", Name = "MOBILEFIX", RewardText = "+$3,500 and +5 Smarts." },
	{ Index = 3, Code = "SORRYMOBILE", Name = "SORRYMOBILE", RewardText = "+$7,500 and +8 Happiness." },
	{ Index = 4, Code = "TRAITS", Name = "TRAITS", RewardText = "+12 CE and +4 Technique Mastery." },
	{ Index = 5, Code = "FAMILYUPDATE", Name = "FAMILYUPDATE", RewardText = "+$4,000, +6 Happiness, and +2 Reputation." },
}

local function getFallbackCodeCards()
	local list = {}
	for _, card in ipairs(DEFAULT_ACTIVE_CODES) do
		table.insert(list, {
			Index = card.Index,
			Code = card.Code,
			Name = card.Name,
			RewardText = card.RewardText,
			Redeemed = false,
		})
	end
	return list
end

local function createCodeStatusNotice(textValue, color)
	local card = createSettingsCard(52)
	card.BackgroundColor3 = THEME.Panel2

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -28, 1, -12)
	label.Position = UDim2.new(0, 14, 0, 6)
	label.BackgroundTransparency = 1
	label.TextColor3 = color or THEME.SubText
	label.TextSize = 12
	label.Font = Enum.Font.GothamBold
	label.TextWrapped = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.Text = tostring(textValue or "")
	label.ZIndex = 54
	label.Parent = card

	return card
end

local function createActiveCodeCard(cardData, index)
	local card = createSettingsCard(78)
	card.BackgroundColor3 = THEME.Panel2

	local colorList = {
		THEME.Gold,
		THEME.Purple,
		THEME.Blue,
		THEME.Green,
		THEME.Orange,
	}
	local accent = colorList[((index - 1) % #colorList) + 1]

	local numberBadge = Instance.new("TextLabel")
	numberBadge.Size = UDim2.new(0, 50, 0, 50)
	numberBadge.Position = UDim2.new(0, 16, 0.5, -25)
	numberBadge.BackgroundColor3 = accent
	numberBadge.BorderSizePixel = 0
	numberBadge.TextColor3 = THEME.Text
	numberBadge.TextSize = 18
	numberBadge.Font = Enum.Font.GothamBlack
	numberBadge.Text = tostring(cardData.Index or index)
	numberBadge.ZIndex = 54
	numberBadge.Parent = card
	addCorner(numberBadge, 12)

	local codeName = Instance.new("TextLabel")
	codeName.Size = UDim2.new(1, -160, 0, 25)
	codeName.Position = UDim2.new(0, 78, 0, 14)
	codeName.BackgroundTransparency = 1
	codeName.TextColor3 = THEME.Text
	codeName.TextSize = 15
	codeName.Font = Enum.Font.GothamBlack
	codeName.TextXAlignment = Enum.TextXAlignment.Left
	codeName.Text = tostring(cardData.Name or cardData.Code or "CODE")
	codeName.ZIndex = 54
	codeName.Parent = card

	local reward = Instance.new("TextLabel")
	reward.Size = UDim2.new(1, -160, 0, 30)
	reward.Position = UDim2.new(0, 78, 0, 38)
	reward.BackgroundTransparency = 1
	reward.TextColor3 = THEME.SubText
	reward.TextSize = 12
	reward.Font = Enum.Font.GothamMedium
	reward.TextWrapped = true
	reward.TextXAlignment = Enum.TextXAlignment.Left
	reward.TextYAlignment = Enum.TextYAlignment.Top
	reward.Text = tostring(cardData.RewardText or cardData.Description or "Reward code.")
	reward.ZIndex = 54
	reward.Parent = card

	local status = Instance.new("TextLabel")
	status.Size = UDim2.new(0, 92, 0, 26)
	status.Position = UDim2.new(1, -102, 0.5, -13)
	status.BackgroundTransparency = 1
	status.TextColor3 = cardData.Redeemed and THEME.Green or accent
	status.TextSize = 12
	status.Font = Enum.Font.GothamBlack
	status.TextXAlignment = Enum.TextXAlignment.Right
	status.Text = cardData.Redeemed and "REDEEMED" or "CODE"
	status.ZIndex = 54
	status.Parent = card

	return card
end

rebuildCodesWindow = function()
	clearSettingsCards()
	createSettingsSectionHeader("Codes")

	local gatePayload = nil
	local ok, result = pcall(function()
		return getCodeGate:InvokeServer(codeLikeConfirmed == true)
	end)

	if ok and typeof(result) == "table" then
		gatePayload = result
	else
		gatePayload = {
			CanUseCodes = false,
			ActiveCodes = getFallbackCodeCards(),
			GroupMessage = "Could not contact the code server.",
			LikeMessage = "Try again after the server finishes loading.",
		}
	end

	local inputCard = createSettingsCard(108)
	inputCard.BackgroundColor3 = THEME.Panel2

	local codeBox = Instance.new("TextBox")
	codeBox.Name = "CodeInput"
	codeBox.Size = UDim2.new(1, -158, 0, 42)
	codeBox.Position = UDim2.new(0, 16, 0, 18)
	codeBox.BackgroundColor3 = THEME.Panel3
	codeBox.BorderSizePixel = 0
	codeBox.PlaceholderText = "TYPE CODE"
	codeBox.Text = ""
	codeBox.TextColor3 = THEME.Text
	codeBox.PlaceholderColor3 = THEME.Muted
	codeBox.TextSize = 13
	codeBox.Font = Enum.Font.GothamBlack
	codeBox.ClearTextOnFocus = false
	codeBox.ZIndex = 55
	codeBox.Parent = inputCard
	addCorner(codeBox, 10)
	addStroke(codeBox, THEME.Stroke, 1)

	local redeemButton = Instance.new("TextButton")
	redeemButton.Name = "RedeemButton"
	redeemButton.Size = UDim2.new(0, 116, 0, 42)
	redeemButton.Position = UDim2.new(1, -132, 0, 18)
	redeemButton.BackgroundColor3 = THEME.Orange
	redeemButton.BorderSizePixel = 0
	redeemButton.TextColor3 = THEME.Text
	redeemButton.TextSize = 12
	redeemButton.Font = Enum.Font.GothamBlack
	redeemButton.Text = "REDEEM"
	redeemButton.AutoButtonColor = false
	redeemButton.ZIndex = 55
	redeemButton.Parent = inputCard
	addCorner(redeemButton, 999)
	addStroke(redeemButton, THEME.Orange, 1)

	local hint = Instance.new("TextLabel")
	hint.Size = UDim2.new(1, -32, 0, 30)
	hint.Position = UDim2.new(0, 16, 0, 68)
	hint.BackgroundTransparency = 1
	hint.TextColor3 = THEME.SubText
	hint.TextSize = 12
	hint.Font = Enum.Font.GothamBold
	hint.TextWrapped = true
	hint.TextXAlignment = Enum.TextXAlignment.Left
	hint.Text = "Try: ALPHA35, MOBILEFIX, SORRYMOBILE, TRAITS, FAMILYUPDATE"
	hint.ZIndex = 55
	hint.Parent = inputCard

	redeemButton.MouseButton1Click:Connect(function()
		local codeText = tostring(codeBox.Text or "")
		if codeText:gsub("%s+", "") == "" then
			createCodeStatusNotice("Type a code first.", THEME.Bad)
			return
		end

		local redeemOk, redeemResult = pcall(function()
			return redeemCode:InvokeServer(codeText, codeLikeConfirmed == true)
		end)

		if redeemOk and typeof(redeemResult) == "table" then
			local color = redeemResult.Success and THEME.Green or THEME.Bad
			createCodeStatusNotice(tostring(redeemResult.Message or "Code checked.") .. (redeemResult.RewardText and redeemResult.RewardText ~= "" and (" " .. tostring(redeemResult.RewardText)) or ""), color)
		else
			createCodeStatusNotice("Could not redeem code right now.", THEME.Bad)
		end

		task.delay(0.2, function()
			if settingsWindow.Visible then
				rebuildCodesWindow()
			end
		end)
	end)

	if gatePayload.CanUseCodes ~= true then
		if gatePayload.GroupMessage then
			createCodeStatusNotice(tostring(gatePayload.GroupMessage), gatePayload.InGroup and THEME.Green or THEME.Gold)
		end
		if gatePayload.LikeMessage then
			createCodeStatusNotice(tostring(gatePayload.LikeMessage), gatePayload.LikeConfirmed and THEME.Green or THEME.Gold)
		end

		if gatePayload.LikeConfirmationRequired == true and gatePayload.LikeConfirmed ~= true then
			createMenuButtonCard("I Liked The Game", "Press this after liking the game to unlock the code box.", THEME.Green, "I LIKED", function()
				codeLikeConfirmed = true
				rebuildCodesWindow()
			end)
		end
	end

	createSettingsSectionHeader("Active Codes")
	local activeCards = gatePayload.ActiveCodes
	if typeof(activeCards) ~= "table" or #activeCards <= 0 then
		activeCards = getFallbackCodeCards()
	end

	for index, cardData in ipairs(activeCards) do
		createActiveCodeCard(cardData, index)
	end

	createMenuButtonCard("Back to Menu", "Return to the main menu hub.", THEME.Red, "BACK", function()
		rebuildSettingsWindow()
	end)
end

rebuildSettingsWindow = function()
	clearSettingsCards()
	createSettingsSectionHeader("Main Menu")
	createMenuButtonCard("Products / Shop", "Gamepasses, boosts, premium packs, and Robux products.", THEME.Gold, "OPEN", function()
		rebuildProductsShop()
	end)
	createMenuButtonCard("Save Slots", "Manage your lives. VIP unlocks Slots 2 and 3.", THEME.Blue, "OPEN", function()
		rebuildSaveSlotsWindow()
	end)
	createMenuButtonCard("Achievements", "Track milestones like first technique, first mission, clan founder, and special grade status.", THEME.Purple, "OPEN", function()
		clearSettingsCards()
		createSettingsSectionHeader("Achievements")
		createMenuNotice("Achievements are not wired yet. This page is ready for milestones like Awakened Technique, First Mission, Clan Founder, and Legacy Continued.")
		createMenuButtonCard("Back to Menu", "Return to the main menu hub.", THEME.Red, "BACK", function()
			rebuildSettingsWindow()
		end)
	end)
	createMenuButtonCard("Settings", "Text, accessibility, audio, and client-side preferences.", THEME.Green, "OPEN", function()
		rebuildSettingsControls()
	end)
	createMenuButtonCard("Codes", "Redeem update rewards and view active codes.", THEME.Orange, "OPEN", function()
		rebuildCodesWindow()
	end)
end

