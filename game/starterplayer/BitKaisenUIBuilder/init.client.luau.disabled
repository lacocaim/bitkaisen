	card.BackgroundColor3 = THEME.Panel2
	card.BorderSizePixel = 0
	card.ZIndex = 53
	card.Parent = settingsScroll
	addCorner(card, 10)
	addStroke(card, THEME.Stroke, 1)
	return card
end

local function createSettingsToggle(titleText, descText, key)
	local card = createSettingsCard(84)

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -150, 0, 22)
	title.Position = UDim2.new(0, 16, 0, 14)
	title.BackgroundTransparency = 1
	title.TextColor3 = THEME.Text
	title.TextSize = 15
	title.Font = Enum.Font.GothamBlack
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Text = titleText
	title.ZIndex = 54
	title.Parent = card

	local desc = Instance.new("TextLabel")
	desc.Size = UDim2.new(1, -150, 0, 32)
	desc.Position = UDim2.new(0, 16, 0, 40)
	desc.BackgroundTransparency = 1
	desc.TextColor3 = THEME.SubText
	desc.TextSize = 12
	desc.Font = Enum.Font.GothamMedium
	desc.TextWrapped = true
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.TextYAlignment = Enum.TextYAlignment.Top
	desc.Text = descText
	desc.ZIndex = 54
	desc.Parent = card

	local toggle = Instance.new("TextButton")
	toggle.Size = UDim2.new(0, 98, 0, 34)
	toggle.Position = UDim2.new(1, -114, 0.5, -17)
	toggle.BackgroundColor3 = currentSettings[key] and THEME.RedDark or THEME.Panel3
	toggle.BorderSizePixel = 0
	toggle.TextColor3 = THEME.Text
	toggle.TextSize = 12
	toggle.Font = Enum.Font.GothamBlack
	toggle.Text = currentSettings[key] and "ON" or "OFF"
	toggle.AutoButtonColor = false
	toggle.ZIndex = 55
	toggle.Parent = card
	addCorner(toggle, 8)
	addStroke(toggle, currentSettings[key] and THEME.RedSoft or THEME.Stroke, 1)

	toggle.MouseButton1Click:Connect(function()
		currentSettings[key] = not currentSettings[key]
		toggle.Text = currentSettings[key] and "ON" or "OFF"
		toggle.BackgroundColor3 = currentSettings[key] and THEME.RedDark or THEME.Panel3
		local stroke = toggle:FindFirstChildOfClass("UIStroke")
		if stroke then
			stroke.Color = currentSettings[key] and THEME.RedSoft or THEME.Stroke
		end
		updateSettingsEvent:FireServer(key, currentSettings[key])
	end)
end

