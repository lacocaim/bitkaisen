local function createMissionCard(missionData)
	local card = Instance.new("Frame")
	card.Size = UDim2.new(1, -10, 0, 116)
	card.BackgroundColor3 = THEME.Panel2
	card.BorderSizePixel = 0
	card.ZIndex = 53
	card.Parent = missionScroll
	addCorner(card, 10)
	addStroke(card, THEME.Stroke, 1)

	local riskColor = missionData.RiskColor or THEME.Muted
	local accent = Instance.new("Frame")
	accent.Name = "RiskAccent"
	accent.Size = UDim2.new(0, 5, 1, -24)
	accent.Position = UDim2.new(0, 12, 0, 11)
	accent.BackgroundColor3 = riskColor
	accent.BorderSizePixel = 0
	accent.ZIndex = 54
	accent.Parent = card
	addCorner(accent, 999)

	local missionName = Instance.new("TextLabel")
	missionName.Size = UDim2.new(1, -190, 0, 28)
	missionName.Position = UDim2.new(0, 28, 0, 14)
	missionName.BackgroundTransparency = 1
	missionName.TextColor3 = THEME.Text
	missionName.TextSize = 18
	missionName.Font = Enum.Font.GothamBlack
	missionName.TextXAlignment = Enum.TextXAlignment.Left
	missionName.Text = tostring(missionData.Title or "Unknown Mission")
	missionName.ZIndex = 54
	missionName.Parent = card

	local missionRisk = Instance.new("TextLabel")
	missionRisk.Size = UDim2.new(1, -190, 0, 22)
	missionRisk.Position = UDim2.new(0, 28, 0, 45)
	missionRisk.BackgroundTransparency = 1
	missionRisk.TextColor3 = riskColor
	missionRisk.TextSize = 13
	missionRisk.Font = Enum.Font.GothamBlack
	missionRisk.TextXAlignment = Enum.TextXAlignment.Left
	missionRisk.Text = "RISK • " .. tostring(missionData.Grade or "Unknown")
	missionRisk.ZIndex = 54
	missionRisk.Parent = card

	local missionReward = Instance.new("TextLabel")
	missionReward.Size = UDim2.new(1, -190, 0, 36)
	missionReward.Position = UDim2.new(0, 28, 0, 70)
	missionReward.BackgroundTransparency = 1
	missionReward.TextColor3 = THEME.SubText
	missionReward.TextSize = 12
	missionReward.Font = Enum.Font.GothamMedium
	missionReward.TextWrapped = true
	missionReward.TextXAlignment = Enum.TextXAlignment.Left
	missionReward.TextYAlignment = Enum.TextYAlignment.Top
	local rewardText = missionData.RewardText
	if not rewardText or rewardText == "" then
		local rewardRep = tonumber(missionData.RewardRep) or 0
		local repText = "Rep +" .. tostring(rewardRep)
		if rewardRep < 0 then repText = "Rep " .. tostring(rewardRep) end
		rewardText = "CE +" .. tostring(missionData.RewardCE or 0) .. " • $" .. tostring(missionData.RewardMoney or 0) .. " • " .. repText
	end
	missionReward.Text = "Reward: " .. tostring(rewardText)
	missionReward.ZIndex = 54
	missionReward.Parent = card

	local acceptBtn = Instance.new("TextButton")
	acceptBtn.Size = UDim2.new(0, 124, 0, 42)
	acceptBtn.Position = UDim2.new(1, -142, 0.5, -21)
	acceptBtn.BackgroundColor3 = THEME.RedDark
	acceptBtn.TextColor3 = THEME.Text
	acceptBtn.TextSize = 13
	acceptBtn.Font = Enum.Font.GothamBlack
	acceptBtn.Text = "ACCEPT"
	acceptBtn.AutoButtonColor = false
	acceptBtn.BorderSizePixel = 0
	acceptBtn.ZIndex = 54
	acceptBtn.Parent = card
	addCorner(acceptBtn, 8)
	addStroke(acceptBtn, THEME.Red, 1)

	acceptBtn.MouseEnter:Connect(function()
		TweenService:Create(acceptBtn, TweenInfo.new(0.12), { BackgroundColor3 = THEME.Red }):Play()
	end)
	acceptBtn.MouseLeave:Connect(function()
		TweenService:Create(acceptBtn, TweenInfo.new(0.12), { BackgroundColor3 = THEME.RedDark }):Play()
	end)
	acceptBtn.MouseButton1Click:Connect(function()
		if not missionData.Id then return end
		updateLifeEvent:FireServer("DoMission", missionData.Id)
		closeModal()
	end)
end

local function createActivityCard(activityData)
	local canDo = activityData.CanDo == true
	local card = Instance.new("Frame")
	card.Size = UDim2.new(1, -10, 0, 172)
	card.BackgroundColor3 = canDo and THEME.Panel2 or Color3.fromRGB(18, 16, 20)
	card.BorderSizePixel = 0
	card.ZIndex = 53
	card.Parent = activityScroll
	addCorner(card, 10)
	addStroke(card, canDo and THEME.Stroke or Color3.fromRGB(70, 35, 42), 1)

	local accentColor = canDo and (activityData.ButtonColor or THEME.Red) or THEME.Muted
	local accent = Instance.new("Frame")
	accent.Size = UDim2.new(0, 5, 1, -22)
	accent.Position = UDim2.new(0, 12, 0, 11)
	accent.BackgroundColor3 = accentColor
	accent.BackgroundTransparency = canDo and 0 or 0.35
	accent.BorderSizePixel = 0
	accent.ZIndex = 54
	accent.Parent = card
	addCorner(accent, 999)

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -56, 0, 30)
	title.Position = UDim2.new(0, 28, 0, 14)
	title.BackgroundTransparency = 1
	title.TextColor3 = canDo and THEME.Text or THEME.Muted
	title.TextSize = 18
	title.Font = Enum.Font.GothamBlack
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Text = tostring(activityData.Title or "Unknown Activity")
	title.ZIndex = 54
	title.Parent = card

	local tag = Instance.new("TextLabel")
	tag.Size = UDim2.new(1, -56, 0, 18)
	tag.Position = UDim2.new(0, 28, 0, 43)
	tag.BackgroundTransparency = 1
	tag.TextColor3 = canDo and accentColor or THEME.Bad
	tag.TextSize = 11
	tag.Font = Enum.Font.GothamBlack
	tag.TextXAlignment = Enum.TextXAlignment.Left
	tag.Text = canDo and "AVAILABLE" or "LOCKED"
	tag.ZIndex = 54
	tag.Parent = card

	local desc = Instance.new("TextLabel")
	desc.Size = UDim2.new(1, -56, 0, 56)
	desc.Position = UDim2.new(0, 28, 0, 64)
	desc.BackgroundTransparency = 1
	desc.TextColor3 = canDo and THEME.SubText or Color3.fromRGB(140, 90, 100)
	desc.TextSize = 12
	desc.Font = Enum.Font.GothamMedium
	desc.TextWrapped = true
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.TextYAlignment = Enum.TextYAlignment.Top
	desc.Text = canDo and tostring(activityData.Description or "") or tostring(activityData.LockedReason or "Locked.")
	desc.ZIndex = 54
	desc.Parent = card

	local doBtn = Instance.new("TextButton")
	doBtn.Size = UDim2.new(0, 132, 0, 36)
	doBtn.Position = UDim2.new(1, -150, 1, -46)
	doBtn.BackgroundColor3 = canDo and THEME.RedDark or Color3.fromRGB(38, 38, 46)
	doBtn.TextColor3 = canDo and THEME.Text or THEME.Muted
	doBtn.TextSize = 13
	doBtn.Font = Enum.Font.GothamBlack
	doBtn.Text = canDo and "DO" or "LOCKED"
	doBtn.AutoButtonColor = false
	doBtn.BorderSizePixel = 0
	doBtn.ZIndex = 54
	doBtn.Parent = card
	addCorner(doBtn, 8)
	addStroke(doBtn, canDo and THEME.Red or THEME.Stroke, 1)

	if canDo then
		doBtn.MouseEnter:Connect(function()
			TweenService:Create(doBtn, TweenInfo.new(0.12), { BackgroundColor3 = THEME.Red }):Play()
		end)
		doBtn.MouseLeave:Connect(function()
			TweenService:Create(doBtn, TweenInfo.new(0.12), { BackgroundColor3 = THEME.RedDark }):Play()
		end)
	end

	doBtn.MouseButton1Click:Connect(function()
		if not activityData.CanDo then return end
		if not activityData.Id then return end
		updateLifeEvent:FireServer("DoActivity", activityData.Id)
		closeModal()
	end)

	return card
end


local function getMissionEmptyMessage()
	local stats = currentStats
	if not stats then return "No missions available.\nLoading your sorcerer profile..." end

	local age = tonumber(stats.Age) or 0
	local grade = tostring(stats.Grade or "Non-Sorcerer")
	local technique = tostring(stats.CursedTechnique or "None")
	local innateTechnique = tostring(stats.InnateTechnique or "None")
	local hasTechnique = technique ~= "None" or innateTechnique ~= "None" or stats.TechniqueKnown == true or stats.TechniqueAwakened == true or stats.TechniqueUsable == true
	local isUnregistered = string.sub(grade, 1, 13) == "Unregistered "
	local isOfficialSorcerer = (stats.InJujutsuHigh == true or stats.RegisteredSorcerer == true) and not isUnregistered

	if age < 16 then return "No official missions available.\nYou need to be at least 16." end
	if not hasTechnique then return "No missions available.\nAwaken a cursed technique first." end
	if not isOfficialSorcerer then
		if isUnregistered then
			return "No official missions available.\nApply to Jujutsu High to register your " .. grade .. "."
		end
		return "No official missions available.\nApply to Jujutsu High and become a registered sorcerer first."
	end
	if stats.TechniqueUsable == false then
		return "No missions available.\nYour technique exists, but it is not usable in missions yet."
	end
	return "No missions available.\nCheck your official grade or try again later."
end

local missionRefreshBusy = false
local activityRefreshBusy = false

local function refreshMissionBoard()
	clearCards(missionScroll)
	local success, board = pcall(function() return getMissionBoard:InvokeServer() end)
	if not success then
		warn("[BitKaisenUIBuilder] Failed to get mission board:", board)
		createMessageCard(missionScroll, "Could not load missions.\nCheck server output.", Color3.fromRGB(220, 90, 90))
		return
	end
	if not board or #board <= 0 then
		createMessageCard(missionScroll, getMissionEmptyMessage(), Color3.fromRGB(180, 180, 190))
		return
	end
	for _, missionData in ipairs(board) do createMissionCard(missionData) end
end

CATEGORY_COLORS = {
	Life = Color3.fromRGB(120, 160, 120),
	School = Color3.fromRGB(55, 100, 170),
	Training = Color3.fromRGB(180, 130, 50),
	["Jujutsu High"] = Color3.fromRGB(95, 165, 255),
	Mentor = Color3.fromRGB(55, 180, 220),
	Missions = Color3.fromRGB(200, 80, 80),
	["Dojo/Clan"] = Color3.fromRGB(120, 70, 120),
	Social = Color3.fromRGB(140, 140, 180),
	Minigames = Color3.fromRGB(200, 160, 60),
	["Curse Spirit"] = Color3.fromRGB(178, 120, 255),
	["Curse User"] = Color3.fromRGB(220, 60, 75),
	Era = Color3.fromRGB(100, 140, 90),
	Premium = Color3.fromRGB(255, 204, 102),
}

CATEGORY_ORDER_CLIENT = {
	"Life", "School", "Training", "Jujutsu High", "Mentor",
	"Missions", "Dojo/Clan", "Social", "Minigames",
	"Curse Spirit", "Curse User", "Era", "Premium",
}

function clearRailButtons()
	for _, btn in ipairs(activityCategoryButtons) do
		if btn and btn.Parent then btn:Destroy() end
	end
	activityCategoryButtons = {}
end

local function refreshActivityList()
	clearCards(activityScroll)
	clearRailButtons()
	createMessageCard(activityScroll, "Loading activities...", Color3.fromRGB(180, 180, 190))
	local success, activities = pcall(function() return getActivityList:InvokeServer() end)
	clearCards(activityScroll)
	if not success then
		warn("[BitKaisenUIBuilder] Failed to get activities:", activities)
		createMessageCard(activityScroll, "Could not load activities.\nCheck server output.", Color3.fromRGB(220, 90, 90))
		return
	end
	if not activities or #activities <= 0 then
		createMessageCard(activityScroll, "No activities available.", Color3.fromRGB(180, 180, 190))
		return
	end

	local grouped = {}
	local presentCategories = {}
	for _, activityData in ipairs(activities) do
		local cat = activityData.Category or "Life"
		if not grouped[cat] then
			grouped[cat] = {}
			table.insert(presentCategories, cat)
		end
		table.insert(grouped[cat], activityData)
	end

	local orderedCats = {}
	for _, cat in ipairs(CATEGORY_ORDER_CLIENT) do
		if grouped[cat] then
			table.insert(orderedCats, cat)
		end
	end
	for _, cat in ipairs(presentCategories) do
		local found = false
		for _, c in ipairs(orderedCats) do
			if c == cat then found = true break end
		end
		if not found then
			table.insert(orderedCats, cat)
		end
	end

	local headerFrames = {}
	local layoutOrder = 0

	for _, cat in ipairs(orderedCats) do
		local catColor = CATEGORY_COLORS[cat] or Color3.fromRGB(160, 160, 180)

		local header = Instance.new("Frame")
		header.Name = "CategoryHeader_" .. cat
		header.Size = UDim2.new(1, -10, 0, 28)
		header.BackgroundColor3 = catColor
		header.BackgroundTransparency = 0.8
		header.BorderSizePixel = 0
		header.LayoutOrder = layoutOrder
		header.ZIndex = 53
		header.Parent = activityScroll
		addCorner(header, 6)

		local headerLabel = Instance.new("TextLabel")
		headerLabel.Size = UDim2.new(1, -12, 1, 0)
		headerLabel.Position = UDim2.new(0, 6, 0, 0)
		headerLabel.BackgroundTransparency = 1
		headerLabel.Font = Enum.Font.GothamBlack
		headerLabel.TextSize = 13
		headerLabel.TextColor3 = catColor
		headerLabel.TextXAlignment = Enum.TextXAlignment.Left
		headerLabel.Text = string.upper(cat)
		headerLabel.ZIndex = 54
		headerLabel.Parent = header

		headerFrames[cat] = header
		layoutOrder += 1

		for _, activityData in ipairs(grouped[cat]) do
			local card = createActivityCard(activityData)
			if card then
				card.LayoutOrder = layoutOrder
				card.Name = "Activity_" .. activityData.Id
			end
			layoutOrder += 1
		end
	end

	for railOrder, cat in ipairs(orderedCats) do
		local catColor = CATEGORY_COLORS[cat] or Color3.fromRGB(160, 160, 180)
		local btn = Instance.new("TextButton")
		btn.Name = "CatBtn_" .. cat
		btn.Size = UDim2.new(1, 0, 0, 28)
		btn.BackgroundColor3 = catColor
		btn.BackgroundTransparency = 0.7
		btn.Font = Enum.Font.GothamBold
		btn.TextSize = 11
		btn.TextColor3 = Color3.fromRGB(230, 230, 240)
		btn.Text = cat
		btn.LayoutOrder = railOrder
		btn.ZIndex = 54
		btn.AutoButtonColor = true
		btn.BorderSizePixel = 0
		btn.Parent = activityCategoryRail
		addCorner(btn, 6)

		btn.MouseButton1Click:Connect(function()
			local headerFrame = headerFrames[cat]
			if headerFrame then
				local yOffset = headerFrame.AbsolutePosition.Y - activityScroll.AbsolutePosition.Y + activityScroll.CanvasPosition.Y
				activityScroll.CanvasPosition = Vector2.new(0, math.max(0, yOffset - 4))
			end
		end)

		table.insert(activityCategoryButtons, btn)
	end
end

logListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
	local contentHeight = logListLayout.AbsoluteContentSize.Y + 40
	lifeLog.CanvasSize = UDim2.new(0, 0, 0, contentHeight)
	lifeLog.CanvasPosition = Vector2.new(0, contentHeight)
end)

local function animateBar(fillFrame, value, maxValue)
	if not fillFrame then return end
	local percent = math.clamp((value or 0) / maxValue, 0, 1)
	TweenService:Create(fillFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(percent, 0, 1, 0)
	}):Play()
end

local LOG_MAX_LINES = 120
local logLines = {}
local lastLoggedAge = nil
local lastLifeWasDead = false
local lastLogMessage = nil
local lastLogTimeKey = nil
local lastLogClock = 0

local function pushLogLine(line)
	table.insert(logLines, tostring(line or ""))
	while #logLines > LOG_MAX_LINES do table.remove(logLines, 1) end
	logText.Text = table.concat(logLines, "\n")
end

local function pushLogBlock(text)
	text = tostring(text or "")
	for line in string.gmatch(text .. "\n", "(.-)\n") do pushLogLine(line) end
end

local function resetLifeLog()
	logLines = {}
	lastLoggedAge = nil
	lastLogMessage = nil
	lastLogTimeKey = nil
	lastLogClock = 0
	logText.Text = "Loading into the Jujutsu world..."
end


function isProfileCurseLife(stats)
	if not stats then return false end
	local race = tostring(stats.Race or "")
	local origin = tostring(stats.Origin or "")
	return stats.IsCurse == true or race == "Cursed Spirit" or race == "Curse" or origin == "Vengeful Spirit Rebirth" or origin == "Cursed Rebirth"
end

function getRoutePathText(stats)
	if not stats then return "Unknown" end
	local gradeText = tostring(stats.Grade or "")

	if isProfileCurseLife(stats) then
		return "Cursed Spirit"
	end

	if stats.IsCurseUser == true
		or stats.CurseUser == true
		or stats.Path == "Curse User"
		or stats.SorcererPath == "Curse User"
		or string.sub(gradeText, 1, 11) == "Curse User" then
		return "Curse User"
	end
	if stats.IsJujutsuMentor == true then
		return "Jujutsu Mentor"
	end
	if stats.InJujutsuHigh == true then
		return "Jujutsu High Sorcerer"
	end
	if stats.GraduatedJujutsuHigh == true or stats.RegisteredSorcerer == true then
		return "Registered Sorcerer"
	end
	if string.find(gradeText, "Unregistered", 1, true) then
		return "Unregistered Sorcerer"
	end
	if tonumber(stats.CursedEnergy or 0) > 0 or tostring(stats.Technique or "") ~= "" then
		return "Awakened Civilian"
	end
	return "Civilian"
end

function getDisplayedAlignment(stats)
	local valid = {
		["Infamous Evil"] = true, ["Evil"] = true, ["Shady"] = true,
		["Neutral"] = true, ["Respected"] = true, ["Honored"] = true,
	}
	local alignment = tostring((stats and stats.Alignment) or "")
	if valid[alignment] then return alignment end

	local reputation = tonumber(stats and stats.Reputation) or 0
	local morality = tonumber(stats and stats.Morality) or 0
	local score = reputation + morality

	if score <= -75 then return "Infamous Evil"
	elseif score <= -35 then return "Evil"
	elseif score <= -10 then return "Shady"
	elseif score < 20 then return "Neutral"
	elseif score < 60 then return "Respected"
	end
	return "Honored"
end

function getProfileProgressText(stats)
	if not stats then return "Progress: N/A" end
	local route = getRoutePathText(stats)

	if route == "Cursed Spirit" then
		local territory = tostring(stats.CurseTerritory or "Unknown Territory")
		local rumor = tostring(stats.CurseRumor or "Unknown Rumor")
		local hunger = math.max(0, tonumber(stats.CurseHunger) or 0)
		local attention = math.max(0, tonumber(stats.SocietyAttention) or tonumber(stats.ExorcismRisk) or 0)
		local status = tostring(stats.SocietyStatus or "Unregistered Cursed Spirit")
		return "Haunt: " .. territory .. " | " .. status .. " | Hunger " .. tostring(hunger) .. "% | Attention " .. tostring(attention) .. "%"
	end

	if route == "Curse User" then
		local current = math.max(0, tonumber(stats.CurseUserProgress) or 0)
		local gradeValue = 1
		local grade = tostring(stats.Grade or "")
		if string.find(grade, "Special Grade", 1, true) then gradeValue = 8
		elseif string.find(grade, "Grade 1", 1, true) then gradeValue = 7
		elseif string.find(grade, "Semi-Grade 1", 1, true) then gradeValue = 6
		elseif string.find(grade, "Grade 2", 1, true) then gradeValue = 5
		elseif string.find(grade, "Semi-Grade 2", 1, true) then gradeValue = 4
		elseif string.find(grade, "Grade 3", 1, true) then gradeValue = 3
		elseif string.find(grade, "Semi-Grade 3", 1, true) then gradeValue = 2
		end
		local requirement = 120 + (gradeValue * 35)
		return "Underground Progress: " .. tostring(current) .. "/" .. tostring(requirement)
	end

	if route == "Unregistered Sorcerer" then
		local current = math.max(0, tonumber(stats.UnregisteredProgress) or 0)
		local grade = tostring(stats.Grade or "")
		local requirement = 50
		if string.find(grade, "Grade 4", 1, true) then requirement = 35
		elseif string.find(grade, "Semi-Grade 3", 1, true) then requirement = 45
		elseif string.find(grade, "Grade 3", 1, true) then requirement = 60
		elseif string.find(grade, "Semi-Grade 2", 1, true) then requirement = 80
		elseif string.find(grade, "Grade 2", 1, true) then requirement = 105
		elseif string.find(grade, "Semi-Grade 1", 1, true) then requirement = 135
		elseif string.find(grade, "Grade 1", 1, true) then requirement = 175
		end
		return "Unregistered Progress: " .. tostring(current) .. "/" .. tostring(requirement)
	end

	return nil
end

function getRouteColor(stats)
	local route = getRoutePathText(stats)
	if route == "Cursed Spirit" then return THEME.Purple or Color3.fromRGB(178, 122, 255)
	elseif route == "Curse User" then return THEME.Red or Color3.fromRGB(220, 60, 75)
	elseif route == "Jujutsu Mentor" then return Color3.fromRGB(55, 180, 220)
	elseif route == "Jujutsu High Sorcerer" then return Color3.fromRGB(95, 165, 255)
	elseif route == "Registered Sorcerer" then return Color3.fromRGB(95, 165, 255)
	elseif route == "Unregistered Sorcerer" then return Color3.fromRGB(180, 120, 255)
	elseif route == "Awakened Civilian" then return Color3.fromRGB(180, 180, 190)
	end
	return Color3.fromRGB(130, 130, 140)
end

function refreshUI(stats, newLogMessage, forceResetLog)
	if not stats then return end
	currentStats = stats

	if forceResetLog == true then
		previousStats = nil
		lastLifeWasDead = false
		resetLifeLog()
		actionRow.Visible = true
		navPanel.Visible = true
	end

	if stats.Alive and lastLifeWasDead then
		previousStats = nil
		resetLifeLog()
		actionRow.Visible = true
		navPanel.Visible = true
		lastLifeWasDead = false
	end

	if previousStats then showStatChanges(previousStats, stats) end

	previousStats = copyStats(stats)
	syncSettingsFromStats(stats)

	nameLabel.Text = tostring(stats.Name or player.Name)
	ageLabel.Text = "Age: " .. getAgeDisplay(stats) .. "  •  Year: " .. tostring(getCurrentYear(stats)) .. "  •  Era: " .. getCurrentEraDisplay(stats)
	yearLabel.Text = ""
	setAgeButtonBlocked(false)
	if isProfileCurseLife(stats) then
		gradeLabel.Text = (stats.CurseClassified == true and "Classification: " or "Estimated: ") .. tostring(stats.CurseGrade or "Unregistered Grade 3 Cursed Spirit")
	else
		gradeLabel.Text = "Rank: " .. tostring(stats.Grade or "Unknown")
	end
	local routePath = getRoutePathText(stats)
	pathLabel.Text = "Path: " .. routePath
	pathLabel.TextColor3 = getRouteColor(stats)
	local lifePath = tostring(stats.LifePath or routePath or "Undecided")
	local fameValue = math.clamp(tonumber(stats.Fame) or 0, 0, 100)
	local fearValue = math.clamp(tonumber(stats.Fear) or 0, 0, 100)
	local supportValue = math.clamp(tonumber(stats.PublicSupport) or 0, 0, 100)
	local hunterValue = math.clamp(tonumber(stats.HunterPressure) or 0, 0, 100)
	local copycats = math.max(0, tonumber(stats.CopycatIncidents) or 0)
	local worldTier = tostring(stats.WorldReputationTier or "Unknown")
	local extras = ""
	if supportValue > 0 then
		extras ..= " | Support " .. tostring(supportValue)
	end
	if hunterValue > 0 then
		extras ..= " | Hunters " .. tostring(hunterValue)
	end
	if copycats > 0 then
		extras ..= " | Copycats " .. tostring(copycats)
	end
	worldRepLabel.Text = "World: " .. lifePath .. " | " .. worldTier .. " | Fame " .. tostring(fameValue) .. " | Fear " .. tostring(fearValue) .. extras
	local affiliation = tostring(stats.Affiliation or (stats.InJujutsuHigh and "Jujutsu High" or "Unaffiliated"))
	local affiliationRank = tostring(stats.AffiliationRank or "None")
	local affiliationRep = math.clamp(tonumber(stats.AffiliationReputation) or 0, 0, 100)
	affiliationLabel.Text = "Affiliation: " .. affiliation .. " | " .. affiliationRank .. " | Rep " .. tostring(affiliationRep)
	local popularity = math.clamp(tonumber(stats.JujutsuHighPopularity) or 0, 0, 100)
	local goodwillWins = math.max(0, tonumber(stats.GoodwillWins) or 0)
	popularityLabel.Text = "Jujutsu High: Popularity " .. tostring(popularity) .. " | Goodwill Wins " .. tostring(goodwillWins)
	local assistantName = stats.AssistantName and tostring(stats.AssistantName) or "None"
	local assistantTrust = math.clamp(tonumber(stats.AssistantTrust) or 0, 0, 100)
	local assistantSkill = math.clamp(tonumber(stats.AssistantSkill) or 0, 0, 100)
	assistantLabel.Text = "Assistant: " .. assistantName .. " | Trust " .. tostring(assistantTrust) .. " | Skill " .. tostring(assistantSkill)
	local techniqueBranch = tostring(stats.TechniqueBranch or "None")
	evolutionLabel.Text = "Technique Stage: " .. tostring(stats.TechniqueEvolutionStage or "Dormant") .. " | " .. techniqueBranch

	local displayAlignment = getDisplayedAlignment(stats)
	if isProfileCurseLife(stats) then
		displayAlignment = tostring(stats.CurseThreatClass or stats.SocietyStatus or "Local")
		alignmentLabel.Text = "Threat Class: " .. displayAlignment
	else
		alignmentLabel.Text = "Alignment: " .. displayAlignment
	end
	if displayAlignment == "Evil" or displayAlignment == "Infamous Evil" then
		alignmentLabel.TextColor3 = THEME.Red
	elseif displayAlignment == "Shady" then
		alignmentLabel.TextColor3 = THEME.Orange
	else
		alignmentLabel.TextColor3 = THEME.Green
	end

	local progressText = getProfileProgressText(stats)
	progressLabel.Visible = progressText ~= nil and progressText ~= ""
	progressLabel.Text = progressText or ""
	progressLabel.TextColor3 = getRouteColor(stats)

	clanLabel.Text = getLineageText(stats)
	techLabel.Text = "Technique: " .. tostring(stats.CursedTechnique or "None")
	positionMasteryQuestionButton()
	traitLabel.Text = "Traits: " .. tostring(stats.TraitSummary or "None")
	ceLabel.Text = "CE Reserves: " .. tostring(stats.CursedEnergy or 0)
	moneyLabel.Text = "Money: $" .. formatMoneyAmount(stats.Money or 0)
	repLabel.Text = "Reputation: " .. tostring(stats.Reputation or 0)

	if (tonumber(stats.Reputation) or 0) < 0 then
		repLabel.TextColor3 = THEME.Red
	else
		repLabel.TextColor3 = THEME.Gold
	end

	recLabel.Text = "Recommendations: " .. tostring(stats.TeacherRecommendations or 0)
	local schoolDisplay = "None"
	if stats.InJujutsuHigh then
		schoolDisplay = "Jujutsu High"
	elseif stats.IsJujutsuMentor then
		schoolDisplay = "Jujutsu Mentor (" .. tostring(stats.MentorRank or "None") .. ")"
	elseif stats.GraduatedJujutsuHigh then
		schoolDisplay = "JJH Graduate"
	elseif stats.GraduatedSchool then
		schoolDisplay = "Graduated"
	else
		local stage = tostring(stats.SchoolStage or "None")
		if stage ~= "None" and stage ~= "Graduated" then
			local perf = math.floor(tonumber(stats.SchoolPerformance) or 50)
			local grade = tostring(stats.ReportCardGrade or "N/A")
			schoolDisplay = stage .. " School | " .. grade .. " (" .. tostring(perf) .. "%)"
		end
	end
	schoolLabel.Text = "School: " .. schoolDisplay

	animateBar(statFills.Health, stats.Health or 100, 100)
	animateBar(statFills.Happiness, stats.Happiness or 100, 100)
	animateBar(statFills.Smarts, stats.Smarts or 50, 100)
	animateBar(statFills.Looks, stats.Looks or 50, 100)
	animateBar(statFills.Strength, stats.Strength or 0, 100)

	if newLogMessage then
		local currentTimeKey = getLogTimeKey(stats)
		local formattedAge = getLogTimeLabel(stats)
		local now = os.clock()
		newLogMessage = tostring(newLogMessage)

		if lastLogMessage == newLogMessage and lastLogTimeKey == currentTimeKey and (now - lastLogClock) < 0.85 then
			return
		end
		lastLogMessage = newLogMessage
		lastLogTimeKey = currentTimeKey
		lastLogClock = now

		if #logLines <= 0 or logText.Text == "Loading into the Jujutsu world..." then
			pushLogLine(formattedAge)
			pushLogBlock(newLogMessage)
			lastLoggedAge = currentTimeKey
			return
		end

		if lastLoggedAge == currentTimeKey then
			pushLogBlock(newLogMessage)
		else
			pushLogLine("")
			pushLogLine(formattedAge)
			pushLogBlock(newLogMessage)
			lastLoggedAge = currentTimeKey
		end
	end
end

function applyButtonAnimations(button)
	if not button then return end
	if button == settingsButton or isMobileViewport() then
		return
	end

	local stroke = button:FindFirstChildOfClass("UIStroke")
	local originalStrokeColor = stroke and stroke.Color or Color3.fromRGB(40, 40, 50)
	local accent = button:FindFirstChild("Accent")
	local defaultBackground = button.BackgroundColor3
	local defaultTextColor = button.TextColor3
	local scaleObject = button:FindFirstChildOfClass("UIScale")
	if not scaleObject then
		scaleObject = Instance.new("UIScale")
		scaleObject.Scale = 1
		scaleObject.Parent = button
	end

	local glow = button:FindFirstChild("HoverGlow")
	if not glow then
		glow = Instance.new("Frame")
		glow.Name = "HoverGlow"
		glow.AnchorPoint = Vector2.new(0.5, 0.5)
		glow.Position = UDim2.new(0.5, 0, 0.5, 0)
		glow.Size = UDim2.new(1, 8, 1, 8)
		glow.BackgroundColor3 = THEME.RedSoft
		glow.BackgroundTransparency = 1
		glow.BorderSizePixel = 0
		glow.ZIndex = math.max(button.ZIndex - 1, 0)
		glow.Parent = button
		addCorner(glow, 12)

		local glowStroke = Instance.new("UIStroke")
		glowStroke.Name = "GlowStroke"
		glowStroke.Color = THEME.RedSoft
		glowStroke.Thickness = 1
		glowStroke.Transparency = 1
		glowStroke.Parent = glow
	end

	local glowStroke = glow:FindFirstChild("GlowStroke")
	local hovered = false
	local pressed = false

	local function tweenScale(targetScale, tweenTime)
		TweenService:Create(scaleObject, TweenInfo.new(tweenTime or 0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Scale = targetScale
		}):Play()
	end

	local function applyVisualState()
		local targetScale = 1
		local targetBackground = defaultBackground
		local targetStroke = originalStrokeColor
		local targetAccent = THEME.Red
		local targetTextColor = defaultTextColor
		local targetGlowTransparency = 1
		local targetGlowStrokeTransparency = 1
		local targetGlowStrokeThickness = 1

		if hovered then
			targetScale = 1.015
			targetBackground = Color3.fromRGB(25, 25, 32)
			targetStroke = Color3.fromRGB(170, 58, 58)
			targetAccent = Color3.fromRGB(255, 90, 90)
			targetTextColor = THEME.Text
			targetGlowTransparency = 0.92
			targetGlowStrokeTransparency = 0.35
			targetGlowStrokeThickness = 2
		end
		if pressed then targetScale = hovered and 0.985 or 0.975 end

		TweenService:Create(button, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundColor3 = targetBackground,
			TextColor3 = targetTextColor
		}):Play()

		if stroke then
			TweenService:Create(stroke, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Color = targetStroke
			}):Play()
		end
		if accent then
			TweenService:Create(accent, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundColor3 = targetAccent
			}):Play()
		end

		TweenService:Create(glow, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = targetGlowTransparency
		}):Play()

		if glowStroke and glowStroke:IsA("UIStroke") then
			TweenService:Create(glowStroke, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Transparency = targetGlowStrokeTransparency,
				Thickness = targetGlowStrokeThickness
			}):Play()
		end

		tweenScale(targetScale, 0.12)
	end

	button.MouseEnter:Connect(function() hovered = true applyVisualState() end)
	button.MouseLeave:Connect(function() hovered = false pressed = false applyVisualState() end)
	button.MouseButton1Down:Connect(function() pressed = true applyVisualState() end)
	button.MouseButton1Up:Connect(function() pressed = false applyVisualState() end)
	button.InputEnded:Connect(function(inputObject)
		if inputObject.UserInputType == Enum.UserInputType.MouseButton1 or inputObject.UserInputType == Enum.UserInputType.Touch then
			pressed = false
			applyVisualState()
		end
	end)
	button.Activated:Connect(function() pressed = false applyVisualState() end)
end

applyButtonAnimations(ageUpButton)
applyButtonAnimations(missionsBtn)
applyButtonAnimations(activitiesBtn)
applyButtonAnimations(relateBtn)
applyButtonAnimations(assetsBtn)
applyButtonAnimations(settingsButton)
applyButtonAnimations(closeMissionBtn)
applyButtonAnimations(closeActivityBtn)
applyButtonAnimations(closeSettingsBtn)
applyButtonAnimations(popupContinue)

