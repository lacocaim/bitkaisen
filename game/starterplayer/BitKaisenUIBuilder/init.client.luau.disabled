	buyButton.BorderSizePixel = 0
	buyButton.TextColor3 = THEME.Text
	buyButton.TextSize = 12
	buyButton.Font = Enum.Font.GothamBlack
	buyButton.Text = item.RobloxId and item.RobloxId > 0 and "BUY" or "SET ID"
	buyButton.AutoButtonColor = false
	buyButton.ZIndex = 55
	buyButton.Parent = card
	addCorner(buyButton, 8)
	addStroke(buyButton, item.RobloxId and item.RobloxId > 0 and THEME.RedSoft or THEME.Stroke, 1)

