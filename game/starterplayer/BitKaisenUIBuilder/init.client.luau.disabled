local function createWindow(name, titleText)
	local window = Instance.new("Frame")
	window.Name = name
	window.Size = UDim2.new(0.56, 0, 0.76, 0)
	window.AnchorPoint = Vector2.new(0.5, 0.5)
	window.Position = UDim2.new(0.5, 0, 0.5, 0)
	window.BackgroundColor3 = THEME.Panel
	window.BorderSizePixel = 0
	window.Visible = false
	window.ZIndex = 51
	window.Parent = overlayPanel
	addCorner(window, 14)
	addStroke(window, THEME.RedSoft, 1)
	setGradient(window, THEME.Panel, THEME.Bg2, 90)

	local title = Instance.new("TextLabel")
	title.Name = "Title"
	title.Size = UDim2.new(1, -96, 0, 42)
	title.Position = UDim2.new(0, 28, 0, 14)
	title.BackgroundTransparency = 1
	title.TextColor3 = THEME.Text
	title.TextSize = 24
	title.Font = Enum.Font.GothamBlack
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Text = titleText
	title.ZIndex = 52
	title.Parent = window

	local closeButton = Instance.new("TextButton")
	closeButton.Name = "CloseButton"
	closeButton.Size = UDim2.new(0, 40, 0, 40)
	closeButton.Position = UDim2.new(1, -54, 0, 16)
	closeButton.BackgroundColor3 = THEME.Panel2
	closeButton.TextColor3 = THEME.Bad
	closeButton.TextSize = 20
	closeButton.Font = Enum.Font.GothamBlack
	closeButton.Text = "X"
	closeButton.AutoButtonColor = false
	closeButton.BorderSizePixel = 0
	closeButton.ZIndex = 52
	closeButton.Parent = window
	addCorner(closeButton, 8)
	addStroke(closeButton, THEME.Stroke, 1)

	local scroll = Instance.new("ScrollingFrame")
	scroll.Name = "Scroll"
	scroll.Size = UDim2.new(1, -56, 1, -78)
	scroll.Position = UDim2.new(0, 28, 0, 60)
	scroll.BackgroundTransparency = 1
	scroll.BorderSizePixel = 0
	scroll.ScrollBarThickness = 5
	scroll.ScrollBarImageColor3 = THEME.RedSoft
	scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	scroll.ScrollingDirection = Enum.ScrollingDirection.Y
	scroll.ScrollingEnabled = true
	scroll.Active = true
	scroll.ElasticBehavior = Enum.ElasticBehavior.WhenScrollable
	scroll.ZIndex = 52
	scroll.Parent = window

	local scrollPadding = Instance.new("UIPadding")
	scrollPadding.PaddingTop = UDim.new(0, 10)
	scrollPadding.PaddingBottom = UDim.new(0, 10)
	scrollPadding.Parent = scroll

	local listLayout = Instance.new("UIListLayout")
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder
	listLayout.Padding = UDim.new(0, 10)
	listLayout.Parent = scroll

	listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 20)
	end)

	return window, closeButton, scroll
end

