	pill.LayoutOrder = order or 0
	pill.ZIndex = 306
	pill.Parent = parent
	addCorner(pill, 6)
	return pill
end

local function normalizeRelationships(result)
	local living = {}
	local dead = {}

	if typeof(result) ~= "table" then
		return living, dead
	end

	if result.Living or result.Deceased then
		for _, item in ipairs(result.Living or {}) do
			table.insert(living, item)
		end
		for _, item in ipairs(result.Deceased or {}) do
			table.insert(dead, item)
		end
		return living, dead
	end

	local source = result.Relationships or result
	for _, relationship in ipairs(source) do
		if relationship.Alive == false then
			table.insert(dead, relationship)
		else
			table.insert(living, relationship)
		end
	end

	return living, dead
end

local function openDetailCard(relationship)
	detailOpen = true

	local name = tostring(relationship.Name or "Unknown")
	local role = tostring(relationship.Role or "Unknown")
	local status = tostring(relationship.Status or "Neutral")
	local age = getRelationshipAge(relationship)
	local gender = getRelationshipGender(relationship)
	local grade = getRelationshipGrade(relationship)
	local technique = getRelationshipTechnique(relationship)
	local ce = getRelationshipCE(relationship)
	local personality = getPersonality(relationship)
	local background = getBackground(relationship)
	local traits = getRelationshipTraits(relationship)
	local alive = relationship.Alive ~= false

	detailName.Text = name
	detailRole.Text = alive and (role .. " • " .. status) or (role .. " • Deceased")
	detailRole.TextColor3 = alive and roleColor(role) or COLORS.Dead
	detailInfo.Text = string.format(
		"<b>Age:</b> %s\n<b>Grade:</b> %s\n<b>Cursed Energy:</b> %s\n<b>Technique:</b> %s\n<b>Traits:</b> %s",
		(age > 0 and tostring(age) or "Unknown"),
		grade,
		tostring(ce),
		technique,
		traits
	)

	local body = "<b>Personality</b>\n" .. personality .. "\n\n<b>Background</b>\n" .. background

	if relationship.YearsKnown and relationship.YearsKnown > 0 then
		body = body .. "\n\nKnown for " .. tostring(relationship.YearsKnown) .. " years."
	end

	if role == "Partner" then
		body = body .. "\nDating for " .. tostring(relationship.YearsDating or 0) .. " years."
	elseif role == "Spouse" then
		body = body .. "\nMarried for " .. tostring(relationship.YearsMarried or 0) .. " years."
	end

	if relationship.Alive == false then
		body = body .. "\n\n<b>Memory</b>\n" .. tostring(relationship.DeathText or (name .. " died."))
	end

	detailBody.Text = body
	applyRelationshipResponsiveLayout()
	detailOverlay.Visible = true
	detailWindow.Visible = true
	detailOverlay.BackgroundTransparency = 1
	detailWindow.BackgroundTransparency = 1
	detailWindow.Position = UDim2.new(0.5, 0, 0.56, 0)

	TweenService:Create(detailOverlay, TweenInfo.new(0.16), { BackgroundTransparency = 0.35 }):Play()
	TweenService:Create(detailWindow, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		Position = UDim2.new(0.5, 0, 0.5, 0),
	}):Play()
end

local function closeDetailCard()
	if not detailOpen then
		return
	end

	detailOpen = false
	TweenService:Create(detailOverlay, TweenInfo.new(0.14), { BackgroundTransparency = 1 }):Play()
	TweenService:Create(detailWindow, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		BackgroundTransparency = 1,
		Position = UDim2.new(0.5, 0, 0.56, 0),
	}):Play()

	task.delay(0.15, function()
		if not detailOpen then
			detailOverlay.Visible = false
			detailWindow.Visible = false
		end
	end)
end

local createActionButtons

local function collapseCard(card)
	local actionsHolder = card:FindFirstChild("ActionsHolder")
	local chevron = card:FindFirstChild("Chevron")
	local bottomHint = card:FindFirstChild("BottomHint")

	if actionsHolder then
		actionsHolder.Visible = false
	end
	if bottomHint then
		bottomHint.Text = "Click to interact"
	end
	if chevron then
		chevron.Text = "▼"
	end

	TweenService:Create(card, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(1, isMobileViewport() and -4 or -10, 0, isMobileViewport() and MOBILE_BASE_CARD_HEIGHT or BASE_CARD_HEIGHT),
	}):Play()
end

local function expandCard(card)
	local actionsHolder = card:FindFirstChild("ActionsHolder")
	local chevron = card:FindFirstChild("Chevron")
	local bottomHint = card:FindFirstChild("BottomHint")

	if not actionsHolder and createActionButtons then
		local relationshipId = card:GetAttribute("RelationshipId")
		local ref = relationshipId and cardRefs[relationshipId]
		if ref and ref.Relationship then
			createActionButtons(card, ref.Relationship)
			actionsHolder = card:FindFirstChild("ActionsHolder")
		end
	end

	if not actionsHolder then
		return
	end

	actionsHolder.Visible = true
	if bottomHint then
		bottomHint.Text = "Choose an action"
	end
	if chevron then
		chevron.Text = "▲"
	end

	local targetHeight = math.max(isMobileViewport() and MOBILE_EXPANDED_CARD_HEIGHT or EXPANDED_CARD_HEIGHT, actionsHolder.Position.Y.Offset + actionsHolder.Size.Y.Offset + 18)

	TweenService:Create(card, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(1, isMobileViewport() and -4 or -10, 0, targetHeight),
	}):Play()
end

createActionButtons = function(parent, relationship)
	local actions = getActionsForRelationship(relationship)
	local actionRows = math.max(1, math.ceil(#actions / 2))
	local holderHeight = 36 + (actionRows * 30) + math.max(0, actionRows - 1) * 8
	local holderY = isMobileViewport() and 204 or 222

	local holder = Instance.new("Frame")
	holder.Name = "ActionsHolder"
	holder.Size = UDim2.new(1, -36, 0, holderHeight)
	holder.Position = UDim2.new(0, 18, 0, holderY)
	holder.BackgroundColor3 = Color3.fromRGB(16, 16, 24)
	holder.BorderSizePixel = 0
	holder.Visible = false
	holder.ZIndex = 306
	holder.Parent = parent
	addCorner(holder, 8)
	addStroke(holder, Color3.fromRGB(40, 40, 56), 1)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -18, 0, 18)
	label.Position = UDim2.new(0, 10, 0, 8)
	label.BackgroundTransparency = 1
	label.TextColor3 = COLORS.SubText
	label.TextSize = 12
	label.Font = Enum.Font.GothamBlack
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = "ACTIONS"
	label.ZIndex = 307
	label.Parent = holder

	local grid = Instance.new("Frame")
	grid.Size = UDim2.new(1, -16, 1, -34)
	grid.Position = UDim2.new(0, 8, 0, 28)
	grid.BackgroundTransparency = 1
	grid.ZIndex = 307
	grid.Parent = holder

	local gridLayout = Instance.new("UIGridLayout")
	gridLayout.CellPadding = UDim2.new(0, 8, 0, 8)
	gridLayout.CellSize = UDim2.new(0.5, -4, 0, 30)
	gridLayout.SortOrder = Enum.SortOrder.LayoutOrder
	gridLayout.Parent = grid

	for index, action in ipairs(actions) do
		local button = Instance.new("TextButton")
		button.Name = "ActionButton_" .. tostring(action.Id)
		button.BackgroundColor3 = COLORS.ActionButton
		button.BorderSizePixel = 0
		button.TextColor3 = Color3.fromRGB(225, 225, 240)
		button.TextSize = 11
		button.Font = Enum.Font.GothamBold
		button.Text = tostring(action.Text)
		button.AutoButtonColor = false
		button.LayoutOrder = index
		button.ZIndex = 307
		button.Parent = grid
		addCorner(button, 7)
		addStroke(button, Color3.fromRGB(50, 50, 68), 1)
		setButtonTween(button, COLORS.ActionHover)

		button.MouseButton1Click:Connect(function()
			if busyAction then
				return
			end

			if action.Confirm == true and button:GetAttribute("Confirmed") ~= true then
				button:SetAttribute("Confirmed", true)
				button.Text = "CONFIRM?"
				button.TextColor3 = COLORS.Bad

				task.delay(2.5, function()
					if button and button.Parent and button:GetAttribute("Confirmed") == true then
						button:SetAttribute("Confirmed", false)
						button.Text = tostring(action.Text)
						button.TextColor3 = Color3.fromRGB(225, 225, 240)
					end
				end)

				return
			end

			local function fireAction(extraData)
				busyAction = true
				pendingRefresh = true
				expandedRelationshipId = relationship.Id
				button.Text = "..."
				button.Active = false
				relationshipAction:FireServer(relationship.Id, action.Id, extraData)
			end

			if canNameChildren and (action.Id == "start_family" or action.Id == "adopt_child") then
				promptChildName(function(childName)
					fireAction({ ChildName = childName })
				end)
			else
				fireAction(nil)
			end

			task.delay(1.2, function()
				if pendingRefresh then
					pendingRefresh = false
					busyAction = false
					if isOpen then
						refreshRelationships(true)
					end
				end
			end)
		end)
	end

	return holder
end

local function promptChildName(callback)
	local promptGui = Instance.new("ScreenGui")
	promptGui.Name = "ChildNamePrompt"
	promptGui.ResetOnSpawn = false
	promptGui.IgnoreGuiInset = true
	promptGui.DisplayOrder = 995
	promptGui.Parent = playerGui

	local shade = Instance.new("Frame")
	shade.Size = UDim2.fromScale(1, 1)
	shade.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	shade.BackgroundTransparency = 0.35
	shade.BorderSizePixel = 0
	shade.Parent = promptGui

	local box = Instance.new("Frame")
	box.AnchorPoint = Vector2.new(0.5, 0.5)
	box.Position = UDim2.fromScale(0.5, 0.5)
	box.Size = UDim2.new(0.86, 0, 0, 164)
	box.BackgroundColor3 = COLORS.Window
	box.BorderSizePixel = 0
	box.Parent = shade
	addCorner(box, 9)
	addStroke(box, COLORS.Stroke, 1)
	local limit = Instance.new("UISizeConstraint")
	limit.MaxSize = Vector2.new(420, 164)
	limit.MinSize = Vector2.new(280, 164)
	limit.Parent = box

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.Position = UDim2.fromOffset(14, 12)
	title.Size = UDim2.new(1, -28, 0, 24)
	title.Text = "CHILD NAME"
	title.TextColor3 = COLORS.Gold
	title.Font = Enum.Font.GothamBlack
	title.TextSize = 16
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = box

	local input = Instance.new("TextBox")
	input.Position = UDim2.fromOffset(14, 48)
	input.Size = UDim2.new(1, -28, 0, 36)
	input.BackgroundColor3 = COLORS.InfoBox
	input.BorderSizePixel = 0
	input.PlaceholderText = "Optional name"
	input.Text = ""
	input.TextColor3 = COLORS.Text
	input.PlaceholderColor3 = COLORS.Muted
	input.Font = Enum.Font.GothamBold
	input.TextSize = 13
	input.ClearTextOnFocus = false
	input.Parent = box
	addCorner(input, 7)
	addStroke(input, COLORS.Stroke, 1)

	local function close(value)
		promptGui:Destroy()
		callback(value)
	end

	local skip = Instance.new("TextButton")
	skip.Position = UDim2.new(0, 14, 1, -50)
	skip.Size = UDim2.new(0.48, -18, 0, 34)
	skip.BackgroundColor3 = COLORS.Button
	skip.BorderSizePixel = 0
	skip.Text = "RANDOM"
	skip.TextColor3 = COLORS.Text
	skip.Font = Enum.Font.GothamBlack
	skip.TextSize = 11
	skip.Parent = box
	addCorner(skip, 7)

	local submit = skip:Clone()
	submit.Position = UDim2.new(0.52, 4, 1, -50)
	submit.Size = UDim2.new(0.48, -18, 0, 34)
	submit.BackgroundColor3 = COLORS.Purple
	submit.Text = "USE NAME"
	submit.Parent = box

	skip.MouseButton1Click:Connect(function() close(nil) end)
	submit.MouseButton1Click:Connect(function() close(input.Text) end)
	input:CaptureFocus()
end

local function createEmptyCard(text)
	local card = Instance.new("Frame")
	card.Name = "EmptyCard"
	card.Size = UDim2.new(1, -10, 0, 94)
	card.BackgroundColor3 = COLORS.Card
	card.BorderSizePixel = 0
	card.ZIndex = 304
	card.Parent = scroll
	addCorner(card, 8)
	addStroke(card, COLORS.Stroke, 1)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -40, 1, 0)
	label.Position = UDim2.new(0, 20, 0, 0)
	label.BackgroundTransparency = 1
	label.TextColor3 = COLORS.SubText
	label.TextSize = 14
	label.Font = Enum.Font.GothamBold
	label.TextWrapped = true
	label.Text = text or "No relationships found."
	label.ZIndex = 305
	label.Parent = card
end

local function createLoadingCard(text)
	clearRelationshipContent()
	makeSectionHeader("Loading", 1)

	local card = Instance.new("Frame")
	card.Name = "LoadingCard"
	card.Size = UDim2.new(1, -10, 0, 94)
	card.BackgroundColor3 = COLORS.Card
	card.BorderSizePixel = 0
	card.ZIndex = 304
	card.Parent = scroll
	addCorner(card, 8)
	addStroke(card, COLORS.Purple, 1)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -40, 1, 0)
	label.Position = UDim2.new(0, 20, 0, 0)
	label.BackgroundTransparency = 1
	label.TextColor3 = COLORS.SubText
	label.TextSize = 14
	label.Font = Enum.Font.GothamBold
	label.TextWrapped = true
	label.Text = text or "Loading relationships..."
	label.ZIndex = 305
	label.Parent = card

	scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 80)
end

local function createRelationshipCard(relationship, order)
	local alive = relationship.Alive ~= false
	local role = tostring(relationship.Role or "Unknown")
	local roleCol = alive and roleColor(role) or COLORS.Dead
	local showRomance = canShowRomanceBar(relationship)
	local mobile = isMobileViewport()
	local small = isSmallMobileViewport()
	local baseHeight = mobile and MOBILE_BASE_CARD_HEIGHT or BASE_CARD_HEIGHT

	local card = Instance.new("Frame")
	card.Name = "RelationshipCard"
	card:SetAttribute("RelationshipId", relationship.Id)
	card.Size = UDim2.new(1, mobile and -4 or -10, 0, baseHeight)
	card.BackgroundColor3 = alive and COLORS.Card or COLORS.CardDead
	card.BorderSizePixel = 0
	card.LayoutOrder = order or 0
	card.ZIndex = 304
	card.Parent = scroll
	addCorner(card, 8)
	addStroke(card, alive and COLORS.Stroke or Color3.fromRGB(65, 65, 75), 1)

	local topButton = Instance.new("TextButton")
	topButton.Name = "TopButton"
	topButton.Size = UDim2.new(1, 0, 1, 0)
	topButton.BackgroundTransparency = 1
	topButton.Text = ""
	topButton.AutoButtonColor = false
	topButton.ZIndex = 304
	topButton.Parent = card

	local name = Instance.new("TextLabel")
	name.Name = "NameLabel"
	name.Size = UDim2.new(1, mobile and -58 or -170, 0, mobile and 22 or 28)
	name.Position = UDim2.new(0, mobile and 12 or 18, 0, mobile and 10 or 14)
	name.BackgroundTransparency = 1
	name.TextColor3 = alive and COLORS.Text or COLORS.Dead
	name.TextSize = small and 12 or (mobile and 14 or 18)
	name.Font = Enum.Font.GothamBlack
	name.TextXAlignment = Enum.TextXAlignment.Left
	name.TextWrapped = false
	name.TextTruncate = Enum.TextTruncate.AtEnd
	name.Text = tostring(relationship.Name or "Unknown")
	name.ZIndex = 305
	name.Parent = card

	local profileButton = Instance.new("TextButton")
	profileButton.Name = "ProfileButton"
	profileButton.Size = UDim2.new(0, mobile and 20 or 26, 0, mobile and 20 or 26)
	profileButton.Position = UDim2.new(1, mobile and -28 or -38, 0, mobile and 11 or 15)
	profileButton.BackgroundColor3 = Color3.fromRGB(38, 28, 60)
	profileButton.BorderSizePixel = 0
	profileButton.TextColor3 = Color3.fromRGB(205, 170, 255)
	profileButton.TextSize = mobile and 11 or 15
	profileButton.Font = Enum.Font.GothamBlack
	profileButton.Text = "?"
	profileButton.AutoButtonColor = false
	profileButton.ZIndex = 308
	profileButton.Parent = card
	addCorner(profileButton, 999)
	addStroke(profileButton, Color3.fromRGB(85, 55, 135), 1)
	setButtonTween(profileButton, Color3.fromRGB(55, 38, 82))

	local roleLabel = Instance.new("TextLabel")
	roleLabel.Name = "RoleLabel"
	roleLabel.Size = UDim2.new(0, mobile and 0 or 90, 0, mobile and 0 or 22)
	roleLabel.Position = UDim2.new(1, mobile and 0 or -136, 0, mobile and 0 or 17)
	roleLabel.BackgroundTransparency = 1
	roleLabel.TextColor3 = roleCol
	roleLabel.TextSize = mobile and 1 or 13
	roleLabel.Font = Enum.Font.GothamBlack
	roleLabel.TextXAlignment = Enum.TextXAlignment.Right
	roleLabel.Text = mobile and "" or (alive and role or (role .. " †"))
	roleLabel.ZIndex = 305
	roleLabel.Parent = card

	local status = Instance.new("TextLabel")
	status.Name = "StatusLabel"
	status.Size = UDim2.new(1, mobile and -24 or -36, 0, mobile and 34 or 18)
	status.Position = UDim2.new(0, mobile and 12 or 18, 0, mobile and 36 or 46)
	status.BackgroundTransparency = 1
	status.TextColor3 = COLORS.SubText
	status.TextSize = small and 8 or (mobile and 9 or 12)
	status.Font = Enum.Font.GothamMedium
	status.TextXAlignment = Enum.TextXAlignment.Left
	status.TextWrapped = true
	status.TextTruncate = Enum.TextTruncate.AtEnd
	status.Text = alive and getStatusLine(relationship) or ("Memory • " .. tostring(relationship.DeathCause or relationship.DeathText or "Deceased"))
	status.ZIndex = 305
	status.Parent = card

	local pillHolder = Instance.new("Frame")
	pillHolder.Name = "PillHolder"
	pillHolder.Size = UDim2.new(1, mobile and -24 or -36, 0, mobile and 22 or 24)
	pillHolder.Position = UDim2.new(0, mobile and 12 or 18, 0, mobile and 72 or 72)
	pillHolder.BackgroundTransparency = 1
	pillHolder.ZIndex = 305
	pillHolder.Parent = card

	local pillLayout = Instance.new("UIListLayout")
	pillLayout.FillDirection = Enum.FillDirection.Horizontal
	pillLayout.SortOrder = Enum.SortOrder.LayoutOrder
	pillLayout.Padding = UDim.new(0, mobile and 4 or 8)
	pillLayout.Parent = pillHolder

	makePill(pillHolder, getRelationshipGrade(relationship), Color3.fromRGB(170, 170, 190), 132, 1)
	makePill(pillHolder, "CE " .. tostring(getRelationshipCE(relationship)), COLORS.Purple, 78, 2)
	makePill(pillHolder, getRelationshipTechnique(relationship), COLORS.Gold, 190, 3)

	makeBar(card, "Bond", relationship.Bond or 0, COLORS.Bond, mobile and 104 or 108)
	makeBar(card, "Trust", relationship.Trust or 0, COLORS.Trust, mobile and 128 or 130)
	makeBar(card, "Respect", relationship.Respect or 0, COLORS.Respect, mobile and 152 or 152)

	if showRomance then
		makeBar(card, "Romance", relationship.Romance or 0, COLORS.Romance, mobile and 176 or 174)
	else
		makeBar(card, "Fear", relationship.Fear or 0, COLORS.Fear, mobile and 176 or 174)
	end

	local bottomHint = Instance.new("TextLabel")
	bottomHint.Name = "BottomHint"
	bottomHint.Size = UDim2.new(1, mobile and -42 or -54, 0, 18)
	bottomHint.Position = mobile and UDim2.new(0, 12, 0, 198) or UDim2.new(0, 18, 1, -22)
	bottomHint.BackgroundTransparency = 1
	bottomHint.TextColor3 = alive and COLORS.Muted or COLORS.Dead
	bottomHint.TextSize = mobile and 9 or 11
	bottomHint.Font = Enum.Font.GothamBold
	bottomHint.TextXAlignment = Enum.TextXAlignment.Left
	bottomHint.Text = alive and "Click to interact" or "Click to manage memory"
	bottomHint.ZIndex = 305
	bottomHint.Parent = card

	local chevron = Instance.new("TextLabel")
	chevron.Name = "Chevron"
	chevron.Size = UDim2.new(0, 14, 0, 14)
	chevron.Position = UDim2.new(1, mobile and -18 or -22, 1, mobile and -16 or -17)
	chevron.BackgroundTransparency = 1
	chevron.TextColor3 = COLORS.Muted
	chevron.TextSize = 12
	chevron.Font = Enum.Font.GothamBlack
	chevron.Text = "▼"
	chevron.ZIndex = 305
	chevron.Parent = card

	profileButton.MouseButton1Click:Connect(function()
		openDetailCard(relationship)
	end)

	topButton.MouseButton1Click:Connect(function()
		if expandedRelationshipId and expandedRelationshipId ~= relationship.Id then
			local previous = cardRefs[expandedRelationshipId]
			if previous and previous.Card then
				collapseCard(previous.Card)
			end
		end

		if expandedRelationshipId == relationship.Id then
			collapseCard(card)
			expandedRelationshipId = nil
			return
		end

		expandedRelationshipId = relationship.Id
		expandCard(card)
	end)

	cardRefs[relationship.Id] = {
		Card = card,
		Relationship = relationship,
		Alive = alive,
	}
end

refreshRelationships = function(preservePosition)
	refreshStamp += 1
	local thisRefresh = refreshStamp

	if refreshInProgress then
		-- Let the newer refresh stamp win, but don't hard-freeze the UI.
		pendingRefresh = true
	end

	refreshInProgress = true

	local previousPosition = preservePosition and scroll.CanvasPosition or Vector2.new(0, 0)
	local previousExpandedId = expandedRelationshipId

	if not preservePosition then
		createLoadingCard("Loading relationships...")
	end

	task.spawn(function()
		local fetchStartedAt = os.clock()
		local success, result = RelationshipCache.Get(false)
		local fetchDuration = os.clock() - fetchStartedAt
		if fetchDuration > 0.35 then
			warn(string.format("[BitKaisenRelationshipsUI] Relationship fetch took %.2fs", fetchDuration))
		end

		if refreshStamp ~= thisRefresh then
			refreshInProgress = false
			return
		end

		cardRefs = {}
		clearRelationshipContent()

		if not success then
			refreshInProgress = false
			busyAction = false
			pendingRefresh = false

			makeSectionHeader("Error", 1)
			createEmptyCard("Could not load relationships.")
			return
		end

		canBrainTransplant = typeof(result) == "table" and result.CanBrainTransplant == true
		canNameChildren = typeof(result) == "table" and result.CanNameChildren == true
		local living, deceased = normalizeRelationships(result)
		currentRelationships = living

		local order = 1
		local renderedCards = 0
		local function yieldForLargeRelationshipLists()
			renderedCards += 1
			if renderedCards % 8 == 0 then
				scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 80)
				task.wait()
			end
		end

		local pageSize = getRelationshipPageSize()
		if #living > 0 then
			local totalPages = math.max(1, math.ceil(#living / pageSize))
			livingPage = math.clamp(livingPage, 1, totalPages)
			local startIndex = ((livingPage - 1) * pageSize) + 1
			local endIndex = math.min(#living, startIndex + pageSize - 1)
			makeSectionHeader("Living Connections (" .. tostring(startIndex) .. "-" .. tostring(endIndex) .. " of " .. tostring(#living) .. ")", order)
			order += 1
			if #living > pageSize then
				makePageControls("Living", #living, livingPage, pageSize, order, function(page) livingPage = page end)
				order += 1
			end

			for index = startIndex, endIndex do
				if refreshStamp ~= thisRefresh then
					refreshInProgress = false
					return
				end
				createRelationshipCard(living[index], order)
				order += 1
				yieldForLargeRelationshipLists()
			end
		end

		if #deceased > 0 then
			local totalPages = math.max(1, math.ceil(#deceased / pageSize))
			deceasedPage = math.clamp(deceasedPage, 1, totalPages)
			local startIndex = ((deceasedPage - 1) * pageSize) + 1
			local endIndex = math.min(#deceased, startIndex + pageSize - 1)
			makeSectionHeader("Deceased / Memories (" .. tostring(startIndex) .. "-" .. tostring(endIndex) .. " of " .. tostring(#deceased) .. ")", order)
			order += 1
			if #deceased > pageSize then
				makePageControls("Deceased", #deceased, deceasedPage, pageSize, order, function(page) deceasedPage = page end)
				order += 1
			end

			for index = startIndex, endIndex do
				if refreshStamp ~= thisRefresh then
					refreshInProgress = false
					return
				end
				createRelationshipCard(deceased[index], order)
				order += 1
				yieldForLargeRelationshipLists()
			end
		end

		if #living <= 0 and #deceased <= 0 then
			makeSectionHeader("Relationships", order)
			createEmptyCard("No relationships found yet.")
		end

		task.defer(function()
			if refreshStamp ~= thisRefresh then
				refreshInProgress = false
				return
			end

			task.wait()

			scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 80)

			if preservePosition then
				scroll.CanvasPosition = previousPosition
			else
				scroll.CanvasPosition = Vector2.new(0, 0)
			end

			if previousExpandedId and cardRefs[previousExpandedId] and cardRefs[previousExpandedId].Alive then
				expandedRelationshipId = previousExpandedId
				expandCard(cardRefs[previousExpandedId].Card)
			else
				expandedRelationshipId = nil
			end

			refreshInProgress = false
			openingWindow = false

			if pendingRefresh and isOpen then
				pendingRefresh = false
				refreshRelationships(true)
			end
		end)
	end)
end


local function hideOtherMenusForRelationships()
	local coreOverlay = bitKaisenGui:FindFirstChild("OverlayPanel")
	if coreOverlay then
		coreOverlay.Visible = false
		local missionWindow = coreOverlay:FindFirstChild("MissionWindow")
		local activityWindow = coreOverlay:FindFirstChild("ActivityWindow")
		local settingsWindow = coreOverlay:FindFirstChild("SettingsWindow")
		if missionWindow then missionWindow.Visible = false end
		if activityWindow then activityWindow.Visible = false end
		if settingsWindow then settingsWindow.Visible = false end
	end

	local assetsOverlay = bitKaisenGui:FindFirstChild("AssetsOverlay")
	if assetsOverlay then
		assetsOverlay.Visible = false
		local assetsWindow = assetsOverlay:FindFirstChild("AssetsWindow")
		if assetsWindow then assetsWindow.Visible = false end
	end
end

local function closeWindowInstant()
	if not isOpen and not overlay.Visible and not detailOverlay.Visible and not refreshInProgress then return end
	refreshStamp += 1
	if detailOpen or detailOverlay.Visible then closeDetailCard() end
	isOpen = false
	openingWindow = false
	refreshInProgress = false
	busyAction = false
	pendingRefresh = false
	expandedRelationshipId = nil
	overlay.BackgroundTransparency = 1
	window.BackgroundTransparency = 1
	detailOverlay.Visible = false
	overlay.Visible = false
	window.Visible = false
end

overlay:GetPropertyChangedSignal("Visible"):Connect(function()
	if not overlay.Visible then
		closeWindowInstant()
	end
end)

local function openWindow()
	local now = os.clock()
	if openingWindow or now - lastOpenClick < 0.35 then
		return
	end
	lastOpenClick = now

	if isOpen then
		return
	end

	openingWindow = true
	isOpen = true
	hideOtherMenusForRelationships()
	applyRelationshipResponsiveLayout()

	overlay.Visible = true
	window.Visible = true
	overlay.BackgroundTransparency = 1
	window.BackgroundTransparency = 1
	window.Position = UDim2.new(0.5, 0, 0.55, 0)

	createLoadingCard("Loading relationships...")

	TweenService:Create(overlay, TweenInfo.new(0.18), { BackgroundTransparency = 0.45 }):Play()
	TweenService:Create(window, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		Position = UDim2.new(0.5, 0, 0.5, 0),
	}):Play()

	task.defer(function()
		if isOpen then
			refreshRelationships(false)
		else
			openingWindow = false
		end
	end)

	task.delay(4.5, function()
		if openingWindow then
			openingWindow = false
		end
	end)
end

local function closeWindow()
	if not isOpen then
		return
	end

	if detailOpen then
		closeDetailCard()
	end

	isOpen = false
	openingWindow = false
	refreshInProgress = false
	busyAction = false
	pendingRefresh = false
	expandedRelationshipId = nil

	TweenService:Create(overlay, TweenInfo.new(0.18), { BackgroundTransparency = 1 }):Play()
	TweenService:Create(window, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		BackgroundTransparency = 1,
		Position = UDim2.new(0.5, 0, 0.55, 0),
	}):Play()

	task.delay(0.19, function()
		if not isOpen then
			overlay.Visible = false
			window.Visible = false
		end
	end)
end

closeButton.MouseButton1Click:Connect(closeWindow)
detailClose.MouseButton1Click:Connect(closeDetailCard)

local function closeRelationshipsBeforeOtherMenu()
	closeWindowInstant()
end

forceCloseEvent.Event:Connect(closeWindowInstant)

if missionsButton then missionsButton.MouseButton1Click:Connect(closeRelationshipsBeforeOtherMenu) end
if activitiesButton then activitiesButton.MouseButton1Click:Connect(closeRelationshipsBeforeOtherMenu) end
if assetsButton then assetsButton.MouseButton1Click:Connect(closeRelationshipsBeforeOtherMenu) end

task.defer(function()
	local menuButton = mainPanel:FindFirstChild("MainMenuButton")
	if menuButton then
		menuButton.MouseButton1Click:Connect(closeRelationshipsBeforeOtherMenu)
	end
end)

relationshipButton.MouseButton1Click:Connect(function()
	if isOpen then
		closeWindow()
	else
		openWindow()
	end
end)

relationshipAction.OnClientEvent:Connect(function()
	busyAction = false

	if isOpen then
		if refreshInProgress then
			pendingRefresh = true
		else
			pendingRefresh = false
			refreshRelationships(true)
		end
	else
		pendingRefresh = false
	end
end)

if game:GetService("RunService"):IsStudio() then print("[BitKaisenRelationshipsUI] Loaded anti-stuck relationships UI.") end

