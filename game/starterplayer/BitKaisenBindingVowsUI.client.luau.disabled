-- LocalScript: BitKaisenBindingVowsUI
-- Location: StarterPlayerScripts
-- Purpose:
--   Clean readable Binding Vows menu.
--   Fixes invisible/unreadable text by using parent-aware ZIndex layering.
--   Preserves:
--     - Preset Vows tab
--     - Custom Binding Vow contracts
--     - GetBindingVows RemoteFunction
--     - BindingVowAction RemoteEvent
--
-- Actions sent:
--   BindingVowAction:FireServer("MakeVow", presetVowId)
--   BindingVowAction:FireServer("BreakVow", presetVowId)
--   BindingVowAction:FireServer("MakeCustomVow", { SacrificeId = "...", RewardId = "...", SeverityId = "..." })
--   BindingVowAction:FireServer("BreakCustomVow", customVowId)

