local function applyMajorPopupResponsiveLayout()
	local camera = workspace.CurrentCamera
	local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
	local isMobile = viewport.X < 900
	local isSmallMobile = viewport.X < 520
	local isLandscapeMobile = isMobile and viewport.X > viewport.Y

	if isLandscapeMobile then
		popupWindow.Size = UDim2.new(0, math.min(600, viewport.X - 96), 0, math.min(232, viewport.Y - 72))
		popupWindow.Position = UDim2.new(0.5, 0, 0.5, 0)
		popupTitle.Size = UDim2.new(1, -28, 0, 26)
		popupTitle.Position = UDim2.new(0, 14, 0, 14)
		popupTitle.TextSize = 16
		popupBody.Size = UDim2.new(1, -36, 0, 44)
		popupBody.Position = UDim2.new(0, 18, 0, 48)
		popupBody.TextSize = 11
		popupHighlight.Size = UDim2.new(1, -36, 0, 34)
		popupHighlight.Position = UDim2.new(0, 18, 0, 106)
		popupHighlight.TextSize = 14
		popupFooter.Size = UDim2.new(1, -36, 0, 30)
		popupFooter.Position = UDim2.new(0, 18, 0, 146)
		popupFooter.TextSize = 10
		popupContinue.Size = UDim2.new(0, 136, 0, 30)
		popupContinue.Position = UDim2.new(0.5, 0, 1, -12)
		popupContinue.TextSize = 10
	elseif isMobile then
		popupWindow.Size = UDim2.new(0.88, 0, 0, isSmallMobile and 286 or 318)
		popupWindow.Position = UDim2.new(0.5, 0, 0.5, 0)
		popupTitle.Size = UDim2.new(1, -28, 0, isSmallMobile and 24 or 28)
		popupTitle.Position = UDim2.new(0, 14, 0, 14)
		popupTitle.TextSize = isSmallMobile and 16 or 18
		popupBody.Size = UDim2.new(1, -28, 0, isSmallMobile and 58 or 66)
		popupBody.Position = UDim2.new(0, 14, 0, isSmallMobile and 48 or 54)
		popupBody.TextSize = isSmallMobile and 11 or 12
		popupHighlight.Size = UDim2.new(1, -28, 0, isSmallMobile and 36 or 42)
		popupHighlight.Position = UDim2.new(0, 14, 0, isSmallMobile and 116 or 132)
		popupHighlight.TextSize = isSmallMobile and 14 or 16
		popupFooter.Size = UDim2.new(1, -28, 0, isSmallMobile and 44 or 50)
		popupFooter.Position = UDim2.new(0, 14, 0, isSmallMobile and 160 or 184)
		popupFooter.TextSize = isSmallMobile and 10 or 11
		popupContinue.Size = UDim2.new(0, isSmallMobile and 132 or 150, 0, 32)
		popupContinue.Position = UDim2.new(0.5, 0, 1, -14)
		popupContinue.TextSize = 11
	else
		popupWindow.Size = UDim2.new(0, 520, 0, 360)
		popupWindow.Position = UDim2.new(0.5, 0, 0.55, 0)
		popupTitle.Size = UDim2.new(1, -56, 0, 38)
		popupTitle.Position = UDim2.new(0, 28, 0, 24)
		popupTitle.TextSize = 24
		popupBody.Size = UDim2.new(1, -70, 0, 76)
		popupBody.Position = UDim2.new(0, 35, 0, 78)
		popupBody.TextSize = 15
		popupHighlight.Size = UDim2.new(1, -70, 0, 44)
		popupHighlight.Position = UDim2.new(0, 35, 0, 166)
		popupHighlight.TextSize = 20
		popupFooter.Size = UDim2.new(1, -70, 0, 48)
		popupFooter.Position = UDim2.new(0, 35, 0, 222)
		popupFooter.TextSize = 12
		popupContinue.Size = UDim2.new(0, 180, 0, 38)
		popupContinue.Position = UDim2.new(0.5, 0, 1, -22)
		popupContinue.TextSize = 13
	end
end

applyMajorPopupResponsiveLayout()
if workspace.CurrentCamera then
	workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(applyMajorPopupResponsiveLayout)
end

local function showNextPopup()
	if popupShowing then return end
	local data = table.remove(popupQueue, 1)
	if not data then return end
	popupShowing = true

	applyMajorPopupResponsiveLayout()
	popupTitle.Text = tostring(data.Title or "EVENT")
	popupBody.Text = tostring(data.Body or "")
	popupHighlight.Text = tostring(data.Highlight or "")
	popupFooter.Text = tostring(data.Footer or "")
	popupFooter.Visible = popupFooter.Text ~= ""

	local popupTone = string.lower(tostring(data.Tone or ""))
	local toneColor = THEME.Purple
	local toneBackground = THEME.Panel2
	if popupTone == "success" then
		toneColor = THEME.Green
		toneBackground = Color3.fromRGB(20, 70, 42)
	elseif popupTone == "danger" or popupTone == "error" then
		toneColor = THEME.Red
		toneBackground = Color3.fromRGB(92, 24, 34)
	end
	popupHighlight.TextColor3 = toneColor
	popupHighlight.BackgroundColor3 = toneBackground
	popupContinue.BackgroundColor3 = toneColor

	popupOverlay.Visible = true
	popupOverlay.BackgroundTransparency = 1
	popupWindow.BackgroundTransparency = 1
	popupWindow.Position = UDim2.new(0.5, 0, 0.55, 0)

	TweenService:Create(popupOverlay, TweenInfo.new(0.25), { BackgroundTransparency = 0.45 }):Play()
	TweenService:Create(popupWindow, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
		Position = UDim2.new(0.5, 0, 0.5, 0)
	}):Play()
end

local function closeCurrentPopup()
	if not popupShowing then return end
	local closeTween = TweenService:Create(popupWindow, TweenInfo.new(0.2), {
		BackgroundTransparency = 1,
		Position = UDim2.new(0.5, 0, 0.55, 0)
	})
	TweenService:Create(popupOverlay, TweenInfo.new(0.2), { BackgroundTransparency = 1 }):Play()
	closeTween:Play()
	closeTween.Completed:Wait()
	popupOverlay.Visible = false
	popupShowing = false
	showNextPopup()
end

local function queueMajorPopup(data)
	table.insert(popupQueue, data)
	showNextPopup()
end

