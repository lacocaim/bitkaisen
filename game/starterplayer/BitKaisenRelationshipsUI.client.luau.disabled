	Bond = Color3.fromRGB(120, 240, 160),
	Trust = Color3.fromRGB(120, 190, 255),
	Respect = Color3.fromRGB(255, 210, 100),
	Fear = Color3.fromRGB(210, 90, 90),
	Romance = Color3.fromRGB(255, 120, 190),
	Purple = Color3.fromRGB(180, 130, 255),
	Gold = Color3.fromRGB(255, 190, 100),
	Dead = Color3.fromRGB(130, 130, 145),
	Bad = Color3.fromRGB(230, 75, 90),
	Button = Color3.fromRGB(33, 33, 44),
