local currentLifeStats = nil
local currentSettings = {
	MusicVolume = 1, SFXVolume = 1, FastText = false, HighContrastText = false
}

local function syncSettingsFromStats(stats)
	currentLifeStats = stats
	if stats and stats.Settings then
		currentSettings.MusicVolume = tonumber(stats.Settings.MusicVolume) or currentSettings.MusicVolume
		currentSettings.SFXVolume = tonumber(stats.Settings.SFXVolume) or currentSettings.SFXVolume
		currentSettings.FastText = stats.Settings.FastText == true
		currentSettings.HighContrastText = stats.Settings.HighContrastText == true
	end
end

local function clearSettingsCards()
	for _, child in ipairs(settingsScroll:GetChildren()) do
		if child:IsA("Frame") or child:IsA("TextLabel") then
			child:Destroy()
		end
	end
end

local function createSettingsSectionHeader(textValue)
	local header = Instance.new("TextLabel")
	header.Size = UDim2.new(1, -8, 0, 24)
	header.BackgroundTransparency = 1
	header.TextColor3 = THEME.SubText
	header.TextSize = 12
	header.Font = Enum.Font.GothamBlack
	header.TextXAlignment = Enum.TextXAlignment.Left
	header.Text = string.upper(textValue)
	header.ZIndex = 53
	header.Parent = settingsScroll
	return header
end

local function createSettingsCard(height)
	local card = Instance.new("Frame")
